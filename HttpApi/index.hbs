// ── Logs tab ──────────────────────────────────────────────────────────────────
function renderLogLines() {
    var filtered = S.logFilter === 'all' ? S.uiLog
        : S.uiLog.filter(function(e) { return e.level === S.logFilter; });
    if (!filtered.length) {
        return '<div class="text-muted text-center py-4 small fst-italic">No log entries yet.'
             + (S.logFilter !== 'all' ? ' Try switching to <strong>All</strong>.' : '')
             + '</div>';
    }
    var levelStyle = {
        ok:   'color:#00cc44',
        info: 'color:#6e7681',
        warn: 'color:#e3b341',
        err:  'color:#f85149',
        rule: 'color:#4d9fff',
        sync: 'color:#bc8cff'
    };
    var levelLabel = { ok:'OK  ', info:'INFO', warn:'WARN', err:'ERR ', rule:'RULE', sync:'SYNC' };
    return filtered.map(function(e) {
        var style = levelStyle[e.level] || 'color:#aaa';
        var label = levelLabel[e.level] || (e.level.toUpperCase() + '    ').slice(0,4);
        return '<div class="tac-log-line">'
             + '<span class="tac-log-time">' + esc(e.time) + '</span>'
             + '<span style="' + style + ';font-weight:600;margin-right:.5em;font-size:.75rem">' + label + '</span>'
             + esc(e.msg)
             + '</div>';
    }).join('');
}

function renderLogs() {
    var filters = [['all','All'],['ok','OK'],['rule','Rule'],['sync','Sync'],['warn','Warn'],['err','Error']];
    var filterBtns = filters.map(function(f) {
        var active = S.logFilter === f[0];
        return '<button type="button" class="btn btn-sm btn-' + (active ? 'primary' : 'outline-secondary') + '"'
             + ' onclick="TAC._setLogFilter(\'' + f[0] + '\')">' + f[1] + '</button>';
    }).join('');
    var header = '<div class="d-flex align-items-center mb-3 gap-2">'
               + '<h5 class="mb-0 fw-semibold">\uD83D\uDDC3\ufe0f Activity Log</h5>'
               + '<div class="btn-group btn-group-sm ms-3">' + filterBtns + '</div>'
               + '<span class="text-muted small ms-2">' + S.uiLog.length + ' entries</span>'
               + '<button type="button" class="btn btn-sm btn-outline-info ms-auto" onclick="TAC._saveLog()">Save to file</button>'
               + ' <button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC._clearUiLog()">Clear</button>'
               + '</div>'
               + '<div class="text-muted small mb-3" style="font-size:.72rem">'
               + 'Frontend activity log. Cross-reference with <code>debug.log</code> in the mod folder for backend events.'
               + '</div>';
    var panel = '<div id="tac-log-panel" class="tac-log-panel" style="max-height:calc(100vh - 200px);min-height:300px">'
              + renderLogLines()
              + '</div>';
    return '<div class="container-fluid py-3">' + header + panel + '</div>';
}

// ── Boot guard — must run before window.TAC is assigned ──────────────────────
// The page loads /automation.js twice (double-registration bug in backend).
// Without this guard here, copy 2 overwrites window.TAC with a fresh S object
// (tab:'dashboard') before hitting the old guard at the bottom — so every button
// call uses the stale S and renders dashboard silently.
if(window.__TAC__)return;
window.__TAC__=true;

// ── Public callbacks ──────────────────────────────────────────────────────────
window.TAC = {
    on:function(name){var l=S.levers.find(function(x){return x.name===name;});if(!l)return;post(l.switchOnUrl).then(function(r){if(r.ok){l.state=true;render();}}).catch(function(e){showErr(e.message);});},
    off:function(name){var l=S.levers.find(function(x){return x.name===name;});if(!l)return;post(l.switchOffUrl).then(function(r){if(r.ok){l.state=false;render();}}).catch(function(e){showErr(e.message);});},
    color:function(name,hex){
        var l=S.levers.find(function(x){return x.name===name;});if(!l||!l.colorUrl)return;
        hex=(hex||'ffffff').replace(/^#/,'').slice(0,6).toLowerCase();
        if(!/^[0-9a-f]{6}$/.test(hex)){showErr('Invalid hex color: '+hex);return;}
        post(l.colorUrl.replace('{color}',hex))
            .then(function(r){if(!r.ok)uiLog('warn','Color set HTTP '+r.status+' for "'+name+'"');})
            .catch(function(e){showErr(e.message);});
    },
    // Legacy aliases kept for any automation rules that stored 'red'/'green' leverState
    red:function(name){TAC.color(name,'ff0000');},
    green:function(name){TAC.color(name,'00ff00');},
    dismiss:function(id){post('/api/beavers/'+id+'/dismiss').then(function(r){if(r.ok){S.beaversLoaded=false;poll();}else showErr('Dismiss failed: '+r.status);}).catch(function(e){showErr(e.message);});},

    // ── Rule list ─────────────────────────────────────────────────────────────
    toggleRule:function(id){var r=S.rules.find(function(r){return r.id===id;});if(!r)return;r.enabled=!r.enabled;saveRules();try{localStorage.removeItem('tac_rules');}catch(e){}render();},
    delRule:function(id){var idx=S.rules.findIndex(function(r){return r.id===id;});if(idx===-1)return;if(S.editingRuleId===id){fbdDetach();S.automationView='list';S.editingRuleId=null;}S.rules.splice(idx,1);saveRules();try{localStorage.removeItem('tac_rules');}catch(e){}render();},
    editRule:function(id){if(!S.rules.find(function(r){return r.id===id;}))return;S.editingRuleId=id;S.automationView='edit';render();},
    newRule:function(){var rule=makeRule('New Rule','simple');S.rules.push(rule);saveRules();S.editingRuleId=rule.id;S.automationView='edit';render();},
    cancelEdit:function(){fbdDetach();S.automationView='list';S.editingRuleId=null;render();},
    saveEdit:function(id){var rule=S.rules.find(function(r){return r.id===id;});if(rule){var nameEl=document.getElementById('editRuleName');if(nameEl&&nameEl.value.trim())rule.name=nameEl.value.trim();if(rule.mode==='code'){var ta=document.getElementById('tac-code-textarea');if(ta){if(!rule.code)rule.code={};rule.code.script=ta.value;}}}fbdDetach();saveRules();S.automationView='list';S.editingRuleId=null;render();},

    // Move rule up (-1) or down (+1) in the list
    moveRule:function(id,dir){var idx=S.rules.findIndex(function(r){return r.id===id;});if(idx===-1)return;var newIdx=idx+dir;if(newIdx<0||newIdx>=S.rules.length)return;var tmp=S.rules[idx];S.rules[idx]=S.rules[newIdx];S.rules[newIdx]=tmp;saveRules();render();},

    // Export all rules as JSON to clipboard
    exportRules:function(){
        var json=JSON.stringify(S.rules,function(k,v){return(k.startsWith('_')||k==='lastError')?undefined:v;},2);
        if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(json).then(function(){showOk('\u2713 Copied '+S.rules.length+' rule'+(S.rules.length!==1?'s':'')+' to clipboard');}).catch(function(){showErr('Copy failed \u2014 open console and copy manually');console.log(json);});}
        else{var ta=document.createElement('textarea');ta.value=json;document.body.appendChild(ta);ta.select();try{document.execCommand('copy');showOk('\u2713 Copied to clipboard');}catch(e){showErr('Copy failed');}document.body.removeChild(ta);}
    },

    // Toggle import panel
    toggleImport:function(){S.showImport=!S.showImport;render();},

    // Import rules from JSON in the textarea
    importRules:function(){
        var ta=document.getElementById('tac-import-ta');if(!ta||!ta.value.trim()){showErr('Paste JSON first');return;}
        try{
            var imported=JSON.parse(ta.value.trim());
            if(!Array.isArray(imported))throw new Error('Expected a JSON array');
            // Validate minimally: each item needs id, name, mode
            imported.forEach(function(r,i){if(!r.id||!r.name||!r.mode)throw new Error('Item '+i+' missing id/name/mode');});
            // Ensure sub-objects exist
            imported=imported.map(function(r){return Object.assign({},makeRule(r.name,r.mode),r);});
            S.rules=imported;saveRules();S.showImport=false;showOk('\u2713 Imported '+imported.length+' rule'+(imported.length!==1?'s':''));render();
        }catch(e){showErr('Import failed: '+e.message);}
    },

    // ── Editor ────────────────────────────────────────────────────────────────
    _setMode:function(id,mode){var rule=S.rules.find(function(r){return r.id===id;});if(!rule)return;if(rule.mode==='code'){var ta=document.getElementById('tac-code-textarea');if(ta){if(!rule.code)rule.code={};rule.code.script=ta.value;}}if(rule.mode==='fbd')fbdDetach();rule.mode=mode;saveRules();render();},
    _addCondition:function(id,type){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;var d={adapter:{type:'adapter',adapterName:(S.adapters[0]&&S.adapters[0].name)||'',adapterState:'on'},lever:{type:'lever',leverName:(S.levers[0]&&S.levers[0].name)||'',leverState:'on'},sensor:{type:'sensor',sensorName:(S.sensors[0]&&S.sensors[0].name)||'',sensorState:'on'},sensor_value:{type:'sensor_value',sensorName:(S.sensors[0]&&S.sensors[0].name)||'',op:'gte',threshold:0},gamestate:{type:'gamestate',field:'isDay'},time:{type:'time',fromHour:6,toHour:20},population:{type:'population',field:'homeless',op:'gt',threshold:0},duration:{type:'duration',adapterName:(S.adapters[0]&&S.adapters[0].name)||'',durationSec:10},popchange:{type:'popchange',field:'totalBeavers',direction:'growing'},daycycle:{type:'daycycle',op:'gt',threshold:1}};if(!d[type])return;r.simple.conditions.push(d[type]);saveRules();render();},
    _addResetCond:function(id,type){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;if(!r.simple.resetConditions)r.simple.resetConditions=[];if(!r.simple.resetCondMode)r.simple.resetCondMode='or';var d={adapter:{type:'adapter',adapterName:(S.adapters[0]&&S.adapters[0].name)||'',adapterState:'off'},lever:{type:'lever',leverName:(S.levers[0]&&S.levers[0].name)||'',leverState:'off'},gamestate:{type:'gamestate',field:'isDay'},time:{type:'time',fromHour:0,toHour:6},population:{type:'population',field:'homeless',op:'eq',threshold:0}};if(!d[type])return;r.simple.resetConditions.push(d[type]);saveRules();render();},
    _removeResetCond:function(id,idx){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple||!r.simple.resetConditions)return;r.simple.resetConditions.splice(idx,1);saveRules();render();},
    _updateResetCond:function(id,idx,key,value){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple||!r.simple.resetConditions||!r.simple.resetConditions[idx])return;r.simple.resetConditions[idx][key]=value;saveRules();render();},
    _removeCondition:function(id,idx){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.conditions.splice(idx,1);saveRules();render();},
    _updateCondition:function(id,idx,key,value){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple||!r.simple.conditions[idx])return;r.simple.conditions[idx][key]=value;saveRules();render();},
    _setCondMode:function(id,mode){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.conditionMode=mode;saveRules();render();},
    _setFuncType:function(id,ft){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.functionType=ft;saveRules();render();},
    _setTimerSec:function(id,val){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.timerSeconds=val>0?val:1;saveRules();},
    _addAction:function(id){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.actions.push({leverName:(S.levers[0]&&S.levers[0].name)||'',leverState:'on'});saveRules();render();},
    _removeAction:function(id,idx){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple)return;r.simple.actions.splice(idx,1);saveRules();render();},
    _updateAction:function(id,idx,key,value){var r=S.rules.find(function(r){return r.id===id;});if(!r||!r.simple||!r.simple.actions[idx])return;r.simple.actions[idx][key]=value;saveRules();render();},
    _saveCode:function(id){var r=S.rules.find(function(r){return r.id===id;});if(!r)return;var ta=document.getElementById('tac-code-textarea');if(!ta)return;if(!r.code)r.code={};r.code.script=ta.value;saveRules();},
    _clearLog:function(id){S.codeLogs[id]=[];var el=document.getElementById('tac-code-log');if(el)el.innerHTML=renderCodeLogLines(id);},
    _copyForAI:function(id){
        var r=S.rules.find(function(r){return r.id===id;});
        var script=(r&&r.code&&r.code.script)||'';
        var gs=S.gameState;
        var pop=S.population;
        var txt='# HTTPAutomation Code Rule — AI Context\n\n'
            +'## Adapters (read-only inputs)\nadapters = '+JSON.stringify(S.adapters.map(function(a){return{name:a.name,state:a.state};}),null,2)+'\n\n'
            +'## Levers (outputs)\nlevers = '+JSON.stringify(S.levers.map(function(l){return{name:l.name,state:l.state};}),null,2)+'\n\n'
            +'## Sensors (automation buildings)\nsensors = '+JSON.stringify(S.sensors.map(function(s){return{name:s.name,type:s.type,unit:s.unit,isOn:s.isOn,value:s.value};}),null,2)+'\n\n'
            +(gs?'## Game State\ngameState = '+JSON.stringify({cycleNumber:gs.cycleNumber,dayNumber:gs.dayNumber,timeOfDayHours:gs.timeOfDayHours,isDay:gs.isDay,isNight:gs.isNight,isDrought:gs.isDrought,isBadtide:gs.isBadtide,weatherId:gs.weatherId,weatherIsHazardous:gs.weatherIsHazardous,weatherDaysRemaining:gs.weatherDaysRemaining},null,2)+'\n\n':'## Game State\ngameState = null  // DLL not loaded\n\n')
            +(pop?'## Population\npopulation = '+JSON.stringify({totalBeavers:pop.totalBeavers,adults:pop.adults,children:pop.children,unemployed:pop.unemployed,homeless:pop.homeless,injured:pop.injured,contaminated:pop.contaminated},null,2)+'\n\n':'## Population\npopulation = null  // DLL not loaded\n\n')
            +'## Available script API\n// setLever(name, \'on\'|\'off\')  — control a lever\n// log(msg)                    — appears in console below editor\n\n'
            +'## Current script\n```js\n'+script+'\n```\n\n'
            +'## Task\n// Describe what you want the script to do:\n';
        if(navigator.clipboard&&navigator.clipboard.writeText){
            navigator.clipboard.writeText(txt).then(function(){showOk('\uD83D\uDCCB Copied context to clipboard — paste into an AI chat');}).catch(function(){showErr('Copy failed');});
        } else {
            var ta=document.createElement('textarea');ta.value=txt;document.body.appendChild(ta);ta.select();
            try{document.execCommand('copy');showOk('\uD83D\uDCCB Copied!');}catch(e){showErr('Copy failed');}
            document.body.removeChild(ta);
        }
    },
    resetLatch:function(id){var r=S.rules.find(function(r){return r.id===id;});if(r&&r.simple)r.simple._latchFired=false;},

    // ── FBD ───────────────────────────────────────────────────────────────────
    _fbdAddNode:function(ruleId,type){var rule=S.rules.find(function(r){return r.id===ruleId;});if(!rule||!FBD_DEFS[type])return;fbdPushUndo(rule);var col=rule.fbd.nodes.length%4,row=Math.floor(rule.fbd.nodes.length/4);var node={id:fbdMakeNodeId(),type:type,x:Math.max(0,-FBD.pan.x/FBD.zoom+20+col*170),y:Math.max(0,-FBD.pan.y/FBD.zoom+20+row*110),params:fbdDefaultParams(type)};rule.fbd.nodes.push(node);FBD.selected=node.id;saveRules();fbdRefreshSidebar(rule);fbdDrawCanvas();},
    _fbdDeleteNode:function(ruleId,nodeId){var rule=S.rules.find(function(r){return r.id===ruleId;});if(!rule)return;fbdPushUndo(rule);if(FBD.selected===nodeId&&FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}rule.fbd.nodes=rule.fbd.nodes.filter(function(n){return n.id!==nodeId;});rule.fbd.edges=rule.fbd.edges.filter(function(e){return e.fromNodeId!==nodeId&&e.toNodeId!==nodeId;});if(FBD.selected===nodeId)FBD.selected=null;saveRules();fbdRefreshSidebar(rule);fbdDrawCanvas();},
    _fbdUpdateParam:function(ruleId,nodeId,key,value){var rule=S.rules.find(function(r){return r.id===ruleId;});if(!rule)return;var node=rule.fbd.nodes.find(function(n){return n.id===nodeId;});if(!node)return;if(!node.params)node.params={};node.params[key]=value;saveRules();fbdRefreshSidebar(rule);fbdDrawCanvas();},
    _fbdOpenFullscreen:function(ruleId){
        var rule=S.rules.find(function(r){return r.id===ruleId;});if(!rule)return;
        fbdDetach();
        // Remove any existing fullscreen overlay
        var old=document.getElementById('tac-fbd-fullscreen');if(old)old.remove();
        var overlay=document.createElement('div');overlay.id='tac-fbd-fullscreen';
        overlay.style.cssText='position:fixed;inset:0;background:#0d1117;z-index:9994;display:flex;flex-direction:column';
        var hdr=document.createElement('div');
        hdr.style.cssText='display:flex;align-items:center;gap:.5rem;padding:.35rem .75rem;background:#1a1f2e;border-bottom:1px solid rgba(255,255,255,.15);flex-shrink:0';
        hdr.innerHTML='<span style="font-size:.85rem;color:#e6edf3;font-weight:600">'+esc(rule.name)+'</span>'
            +'<span class="text-muted" style="font-size:.72rem">Right-click to add nodes \u2022 Scroll=zoom \u2022 Space+drag=pan \u2022 Del=remove \u2022 F=fit \u2022 Ctrl+Z=undo</span>'
            +'<button type="button" id="tac-fbd-fs-close" style="margin-left:auto;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);color:#e6edf3;padding:.15rem .55rem;border-radius:.25rem;cursor:pointer;font-size:.85rem">\u2715 Close</button>';
        var wrap=document.createElement('div');wrap.style.cssText='flex:1;overflow:hidden;position:relative';
        var canvas=document.createElement('canvas');canvas.id='tac-fbd-canvas';canvas.style.cssText='display:block';
        wrap.appendChild(canvas);overlay.appendChild(hdr);overlay.appendChild(wrap);document.body.appendChild(overlay);
        canvas.width=wrap.clientWidth||window.innerWidth;canvas.height=wrap.clientHeight||(window.innerHeight-42);
        FBD.canvas=canvas;FBD.ctx=canvas.getContext('2d');
        if(FBD.ruleId!==rule.id){FBD.pan={x:20,y:20};FBD.zoom=1.0;FBD.selected=null;FBD.wire=null;}
        FBD.ruleId=rule.id;
        canvas.addEventListener('mousedown',fbdOnMouseDown);canvas.addEventListener('mousemove',fbdOnMouseMove);canvas.addEventListener('mouseup',fbdOnMouseUp);canvas.addEventListener('contextmenu',fbdOnContextMenu);canvas.addEventListener('wheel',fbdOnWheel,{passive:false});
        document.addEventListener('keydown',fbdOnKeyDown);document.addEventListener('keyup',fbdOnKeyUp);
        if(rule.fbd&&rule.fbd.nodes&&rule.fbd.nodes.length)fbdFitToScreen();else fbdDrawCanvas();
        function closeFs(){fbdDetach();overlay.remove();}
        document.getElementById('tac-fbd-fs-close').addEventListener('click',closeFs);
        var escFn=function(e){if(e.key==='Escape'){closeFs();document.removeEventListener('keydown',escFn);}};
        document.addEventListener('keydown',escFn);
    },

    // ── Logs tab ──────────────────────────────────────────────────────────────
    _setLogFilter:function(f){S.logFilter=f;render();},
    _clearUiLog:function(){S.uiLog=[];render();},
    _saveLog:function(){
        var levelLabel={ok:'OK  ',info:'INFO',warn:'WARN',err:'ERR ',rule:'RULE',sync:'SYNC'};
        var lines=S.uiLog.map(function(e){
            var label=levelLabel[e.level]||(e.level.toUpperCase()+'    ').slice(0,4);
            return e.time+' '+label+' '+e.msg;
        });
        var body=lines.join('\n');
        fetch('/api/log',{method:'POST',headers:{'Content-Type':'text/plain'},body:body})
            .then(function(r){if(r.ok)showOk('\u2713 Log saved to ui_log.txt in mod folder');else showErr('Save failed: HTTP '+r.status);})
            .catch(function(e){showErr('Save failed: '+(e.message||e));});
    }
};

// ── Boot ──────────────────────────────────────────────────────────────────────
// ── Takeover ──────────────────────────────────────────────────────────────────
if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',takeover);
else takeover();

})();
</script>
