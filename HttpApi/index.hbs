// ── Code mode editor ──────────────────────────────────────────────────────────
function renderCodeEditor(rule){
    var rid=esc(rule.id),script=(rule.code&&rule.code.script)||'';
    // Live state sidebar
    var adRows=S.adapters.map(function(a){return'<div style="display:flex;justify-content:space-between;padding:1px 0;font-size:.75rem"><span style="color:#8b949e">'+esc(a.name)+'</span><span style="color:'+(a.state?'#00d000':'#6c757d')+'">'+(a.state?'ON':'OFF')+'</span></div>';}).join('')||'<div style="color:#6c757d;font-size:.75rem">none</div>';
    var lvRows=S.levers.map(function(l){return'<div style="display:flex;justify-content:space-between;padding:1px 0;font-size:.75rem"><span style="color:#8b949e">'+esc(l.name)+'</span><span style="color:'+(l.state?'#00d000':'#6c757d')+'">'+(l.state?'ON':'OFF')+'</span></div>';}).join('')||'<div style="color:#6c757d;font-size:.75rem">none</div>';
    var stateSidebar='<div style="width:180px;flex-shrink:0;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:.375rem;padding:.6rem;font-family:Consolas,monospace;overflow-y:auto;max-height:380px">'
        +'<div style="color:#e3b341;font-size:.7rem;font-weight:600;text-transform:uppercase;margin-bottom:.4rem">Adapters</div>'+adRows
        +'<div style="color:#e3b341;font-size:.7rem;font-weight:600;text-transform:uppercase;margin:.7rem 0 .4rem">Levers</div>'+lvRows
        +'</div>';
    var refCard='<div class="card mb-3" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1)"><div class="card-body py-2 px-3"><div class="text-muted small fw-semibold mb-2">AVAILABLE IN SCRIPT</div><div class="row g-2 small"><div class="col-md-6"><code class="text-warning">adapters</code> <span class="text-muted">\u2014 array of <code>{name, state}</code></span></div><div class="col-md-6"><code class="text-warning">levers</code> <span class="text-muted">\u2014 array of <code>{name, state}</code> (read-only)</span></div><div class="col-md-6"><code class="text-warning">sensors</code> <span class="text-muted">\u2014 array of <code>{id, name, type, unit, isOn, value}</code></span></div><div class="col-md-6"><code class="text-warning">gameState</code> <span class="text-muted">\u2014 <code>{cycleNumber, dayNumber, timeOfDayHours, isDay, isNight, isDrought, isBadtide, isHazardous, weatherId, weatherIsHazardous, weatherDaysRemaining}</code> or null</span></div><div class="col-md-6"><code class="text-warning">population</code> <span class="text-muted">\u2014 <code>{totalBeavers, adults, children, unemployed, homeless, injured, contaminated}</code> or null</span></div><div class="col-md-6"><code class="text-success">setLever(name, state)</code> <span class="text-muted">\u2014 <code>\'on\'</code> or <code>\'off\'</code></span></div><div class="col-md-6"><code class="text-success">log(msg)</code> <span class="text-muted">\u2014 appends to console below</span></div></div><div class="mt-2 text-muted" style="font-size:.75rem">Script runs every ~0.5 s while enabled. Errors appear in console and as a badge on the rule list.</div></div></div>';
    return'<div class="card" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1)"><div class="card-body">'+refCard
