function fbdOnKeyDown(e){
    if(e.code==='Space'&&e.target.tagName!=='INPUT'&&e.target.tagName!=='TEXTAREA'){FBD.spaceDown=true;e.preventDefault();}
    if((e.key==='Delete'||e.key==='Backspace')&&FBD.selected&&e.target.tagName!=='INPUT'&&e.target.tagName!=='TEXTAREA'){TAC._fbdDeleteNode(FBD.ruleId,FBD.selected);e.preventDefault();}
    if((e.key==='f'||e.key==='F')&&e.target.tagName!=='INPUT'&&e.target.tagName!=='TEXTAREA'){fbdFitToScreen();}
    if(e.key==='z'&&(e.ctrlKey||e.metaKey)&&e.target.tagName!=='INPUT'&&e.target.tagName!=='TEXTAREA'){var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});if(rule)fbdUndo(rule);e.preventDefault();}
