    document.removeEventListener('keydown',fbdOnKeyDown);document.removeEventListener('keyup',fbdOnKeyUp);
    var wrap=canvas.parentElement;canvas.width=wrap?Math.max(400,wrap.clientWidth-4):700;canvas.height=560;
    FBD.canvas=canvas;FBD.ctx=canvas.getContext('2d');
    if(FBD.ruleId!==rule.id){if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}FBD.pan={x:20,y:20};FBD.zoom=1.0;FBD.selected=null;FBD.wire=null;}
    FBD.ruleId=rule.id;
    canvas.addEventListener('mousedown',fbdOnMouseDown);canvas.addEventListener('mousemove',fbdOnMouseMove);canvas.addEventListener('mouseup',fbdOnMouseUp);canvas.addEventListener('contextmenu',fbdOnContextMenu);canvas.addEventListener('wheel',fbdOnWheel,{passive:false});
