function fbdOnContextMenu(e) {
    e.preventDefault();var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});if(!rule)return;
    var w=fbdScreenToWorld(e.clientX,e.clientY);
    var node=fbdNodeAt(w.x,w.y,rule.fbd.nodes);
    if(node){
        fbdPushUndo(rule);
        if(FBD.selected===node.id)FBD.selected=null;
        if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}
        rule.fbd.nodes=rule.fbd.nodes.filter(function(n){return n.id!==node.id;});
        rule.fbd.edges=rule.fbd.edges.filter(function(ed){return ed.fromNodeId!==node.id&&ed.toNodeId!==node.id;});
        saveRules();fbdDrawCanvas();return;
    }
    var edge=fbdHitEdge(w.x,w.y,rule.fbd.nodes,rule.fbd.edges);
    if(edge){fbdPushUndo(rule);rule.fbd.edges=rule.fbd.edges.filter(function(ed){return ed.id!==edge.id;});saveRules();fbdDrawCanvas();return;}
