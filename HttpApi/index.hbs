// ── DOM take-over ─────────────────────────────────────────────────────────────
function takeover() {
    // Remove ALL known stock game UI elements.
    // The game's index.hbs uses nav.navbar.fixed-top and main.container-fluid,
    // NOT header.container / main.container (old wrong selectors).
    // Also remove the stock errAlert div so it doesn't conflict with ours.
    // We try multiple selectors in case the game template changes between versions.
    // HIDE rather than remove stock game elements.
    // The game's inline SPA still holds references to #tab-dashboard etc. and calls
    // .innerHTML on them every 3 seconds. If we remove() those elements, the next
    // getElementById() returns null and .innerHTML = ... throws a TypeError — which
    // CEF treats as a fatal Promise error and reloads the page, kicking the user back
    // to Dashboard. Hiding them lets SPA1 write harmlessly to invisible elements.
    ['nav.navbar.fixed-top','main.container-fluid','header.container','main.container','#errAlert'].forEach(function(sel){
        var el=document.querySelector(sel);if(el)el.style.display='none';
    });
    var TAC_BTN_STYLE='background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.2);border-radius:.3rem;color:#e6edf3;cursor:pointer;font-size:.8rem;padding:.2rem .55rem;transition:background .15s';
    var root=document.createElement('div');root.id='tac-root';
    root.innerHTML=['<nav id="tac-nav" style="background:#1a1f2e;border-bottom:1px solid rgba(255,255,255,.18);padding:.35rem .75rem;display:flex;align-items:center;gap:.5rem;position:sticky;top:0;z-index:1030">','  <span style="font-weight:700;color:#e6edf3;margin-right:.5rem;white-space:nowrap">\uD83E\uDDB8 HTTPAutomation</span>','  <span id="tac-savename" style="font-size:.78rem;color:#8b949e;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>','  <span id="tac-poll-light" title="Polling" style="width:9px;height:9px;border-radius:50%;background:#555;flex-shrink:0;box-shadow:0 0 0 2px rgba(0,0,0,.4)"></span>','  <span id="tac-status" style="font-size:.75rem;color:#8b949e;margin-left:auto"></span>','  <div id="tac-tabs" style="display:flex;gap:3px">','    <button type="button" data-tab="dashboard"  style="'+TAC_BTN_STYLE+'">Dashboard</button>','    <button type="button" data-tab="levers"     style="'+TAC_BTN_STYLE+'">Levers</button>','    <button type="button" data-tab="adapters"   style="'+TAC_BTN_STYLE+'">Adapters</button>','    <button type="button" data-tab="sensors"    style="'+TAC_BTN_STYLE+'">Sensors</button>','    <button type="button" data-tab="population" style="'+TAC_BTN_STYLE+'">Population</button>','    <button type="button" data-tab="automation" style="'+TAC_BTN_STYLE+'">Automation</button>','    <button type="button" data-tab="logs"       style="'+TAC_BTN_STYLE+'">Logs</button>','  </div>','</nav>','<div id="tac-content" style="min-height:calc(100vh - 46px)"></div>','<div id="tac-err" class="alert alert-danger position-fixed bottom-0 start-50 translate-middle-x d-none mb-3 shadow" style="z-index:9999;text-align:center;min-width:220px"></div>'].join('');
    document.body.appendChild(root);
    var style=document.createElement('style');
    style.textContent=['body,html{background-color:#0d1117!important;padding:0!important;margin:0!important}','#tac-root{background:#0d1117;min-height:100vh}','#tac-nav button[data-tab]:hover{background:rgba(255,255,255,.15)!important}','#tac-nav button[data-tab].active{background:rgba(79,140,255,.35)!important;border-color:rgba(79,140,255,.7)!important}','.tac-on{color:#00d000;font-weight:600}','.tac-off{color:#6c757d}','.tac-spr{color:#dbd51a;font-weight:600}','.card-sm .card-body{padding:.5rem .75rem}','#tac-tabs .btn.active{background:rgba(255,255,255,.15)!important}','body{background-color:#212529}','.tac-rule-row:hover{background:rgba(255,255,255,.04)}','.tac-mode-simple{background:#6c757d!important}','.tac-mode-fbd{background:#0dcaf0!important;color:#000!important}','.tac-mode-code{background:#ffc107!important;color:#000!important}','.tac-cond-row{background:rgba(255,255,255,.05);border-radius:.375rem}','.tac-cond-row select,.tac-cond-row input{max-width:none}','.tac-code-area{font-family:Consolas,Menlo,"Courier New",monospace;font-size:.82rem;background:#0d1117;color:#e6edf3;border:1px solid rgba(255,255,255,.15);resize:vertical;min-height:220px;width:100%;border-radius:.375rem;padding:.6rem .8rem;line-height:1.5;outline:none}','.tac-code-area:focus{border-color:#0d6efd;box-shadow:0 0 0 .2rem rgba(13,110,253,.25)}','.tac-log-panel{font-family:Consolas,Menlo,"Courier New",monospace;font-size:.78rem;background:#0d1117;border:1px solid rgba(255,255,255,.1);border-radius:.375rem;padding:.5rem .75rem;max-height:180px;overflow-y:auto;min-height:60px}','.tac-log-line{padding:1px 0;border-bottom:1px solid rgba(255,255,255,.04);white-space:pre-wrap;word-break:break-all}','.tac-log-line:last-child{border-bottom:none}','.tac-log-err{color:#f85149}','.tac-log-time{color:#6e7681;margin-right:.5em;user-select:none}','.tac-import-box{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.15);border-radius:.375rem;padding:.75rem;margin-bottom:.75rem}'].join('\n');
    document.head.appendChild(style);
    document.getElementById('tac-tabs').addEventListener('click',function(e){var btn=e.target.closest('button[data-tab]');if(!btn)return;switchTab(btn.dataset.tab);});
    uiLog('ok', 'HTTPAutomation started \u2014 '
        + S.rules.length + ' rule' + (S.rules.length!==1?'s':'') + ' from localStorage'
        + (S.levers.length   ? ', ' + S.levers.length   + ' levers'   : '')
        + (S.adapters.length ? ', ' + S.adapters.length + ' adapters' : ''));
    // Check for welcome.json popup before showing the dashboard
    get('/api/welcome').then(function(w){
        if(w&&w.title){
            showWelcomeModal(w.title, w.text||'');
        }
    }).catch(function(){/* 404 = no file, silent */});
    switchTab('dashboard');poll();setInterval(poll,500);
}

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(name) {
    if(S.tab==='automation'&&name!=='automation'){fbdDetach();S.automationView='list';S.editingRuleId=null;S.showImport=false;}
    S.tab=name;
    document.querySelectorAll('#tac-tabs button').forEach(function(b){b.classList.toggle('active',b.dataset.tab===name);});
    if(name==='population'&&!S.beaversLoaded)fetchBeavers();
    render();
}

// ── API helpers ───────────────────────────────────────────────────────────────
function get(path){return fetch(path,{cache:'no-store'}).then(function(r){if(r.status===404)return Promise.reject({status:404,notFound:true});if(!r.ok)return Promise.reject({status:r.status});return r.json()});}
function post(url){return fetch(url,{method:'POST',cache:'no-store'});}
function showErr(msg){var el=document.getElementById('tac-err');if(!el)return;el.textContent=msg;el.classList.remove('d-none');clearTimeout(showErr._t);showErr._t=setTimeout(function(){el.classList.add('d-none');},4000);}
function showOk(msg){var el=document.getElementById('tac-err');if(!el)return;el.textContent=msg;el.className='alert alert-success position-fixed bottom-0 start-50 translate-middle-x mb-3 shadow';el.style.zIndex='9999';el.style.minWidth='220px';el.style.textAlign='center';clearTimeout(showErr._t);showErr._t=setTimeout(function(){el.classList.add('d-none');el.className='alert alert-danger position-fixed bottom-0 start-50 translate-middle-x d-none mb-3 shadow';},2500);}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ── Poll ──────────────────────────────────────────────────────────────────────
function poll() {
    if(S.polling)return;S.polling=true;
    var leversP=get('/api/levers').catch(function(){return null;});
    var adaptersP=get('/api/adapters').catch(function(){return null;});
    var sensorsP=DLL_AVAILABLE===false?Promise.resolve(null):get('/api/sensors').catch(function(){return null;});
    var gsP=DLL_AVAILABLE===false?Promise.resolve(null):get('/api/gamestate').catch(function(e){if(e&&e.notFound)DLL_AVAILABLE=false;return null;});
    var popP=DLL_AVAILABLE===false?Promise.resolve(null):get('/api/population').catch(function(){return null;});
    var beaversP=(S.tab==='population'&&DLL_AVAILABLE!==false)?get('/api/beavers').catch(function(){return null;}):Promise.resolve(null);
    Promise.all([leversP,adaptersP,gsP,popP,beaversP,sensorsP]).then(function(res){
        try {
        // Merge poll data into S.levers rather than replacing entirely, so URL fields
        // seeded from window.TB.levers at boot are preserved for levers the backend
        // doesn't re-include. Also picks up colorUrl (new in v5.0.0 API).
        if(res[0]){
            res[0].forEach(function(fresh){
                var ex=S.levers.find(function(l){return l.name===fresh.name;});
                if(ex){
                    ex.state=fresh.state;
                    ex.isSpringReturn=fresh.springReturn||fresh.isSpringReturn||false;
                    if(fresh.colorUrl) ex.colorUrl=fresh.colorUrl;
                    if(fresh.switchOnUrl)  ex.switchOnUrl=fresh.switchOnUrl;
                    if(fresh.switchOffUrl) ex.switchOffUrl=fresh.switchOffUrl;
                } else {
                    // New lever added mid-session — add it with whatever the API gave us
                    S.levers.push({
                        name:fresh.name, state:fresh.state,
                        isSpringReturn:fresh.springReturn||fresh.isSpringReturn||false,
                        switchOnUrl:fresh.switchOnUrl||'', switchOffUrl:fresh.switchOffUrl||'',
                        colorUrl:fresh.colorUrl||''
                    });
                }
            });
        }
        if(res[1])S.adapters=res[1];

        // Track DLL state transitions for logging (declare before the if so scope is clean)
        var prevDll = DLL_AVAILABLE;
        if(res[2]){
            S.gameState=res[2]; DLL_AVAILABLE=true;
            var newSave=res[2].saveName||'';
            if(newSave && newSave!==S.currentSaveName) loadRulesFromServer(newSave);
            if(prevDll===false) uiLog('ok','DLL came online \u2014 game state and population now available');
        } else if(prevDll===true || prevDll===null) {
            // Transitioned to offline (or first poll with no gamestate)
            if(prevDll===true) uiLog('warn','DLL went offline \u2014 /api/gamestate returned 404');
        }

        if(res[3])S.population=res[3];
        if(res[4]){S.beavers=res[4];S.beaversLoaded=true;}
        if(res[5]&&Array.isArray(res[5].sensors))S.sensors=res[5].sensors;
        else if(res[5]&&Array.isArray(res[5]))S.sensors=res[5];

        runAutomation();

        // Update clock + poll status light
        var st=document.getElementById('tac-status');
        if(st){var now=new Date();st.textContent=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0')+':'+now.getSeconds().toString().padStart(2,'0');}
        var dot=document.getElementById('tac-poll-light');
        if(dot){var gotData=res[0]||res[1];if(gotData){dot.style.background='#00cc44';dot.style.boxShadow='0 0 6px #00cc44,0 0 0 2px rgba(0,0,0,.4)';}else{dot.style.background='#f85149';dot.style.boxShadow='0 0 6px #f85149,0 0 0 2px rgba(0,0,0,.4)';}}

        // ── Selective re-render after poll ────────────────────────────────────
        // Only re-render tabs that show live game data.
        // - automation tab: list is stable between user actions; edit mode has dedicated updaters.
        //   loadRulesFromServer() calls render() itself when on automation tab.
        // - logs tab: self-patches via #tac-log-panel id; a full render would destroy scroll position.
        // Rebuilding DOM every 3 s was destroying any interaction (clicks, open panels, focus).
        if(S.tab==='automation'){
            if(S.automationView==='edit'){
                var er=S.rules.find(function(r){return r.id===S.editingRuleId;});
                if(er&&er.mode==='code') updateCodeLogPanel();
                else if(er&&er.mode==='fbd') fbdDrawCanvas();
                // simple editor: no live update needed while user is editing
            }
            // list view: don't re-render from poll — rules only change on user action or save load
        } else if(S.tab==='logs'){
            // uiLog() patches #tac-log-panel directly; no full render needed
        } else {
            // dashboard, levers, adapters, sensors, population — live data worth refreshing
            render();
        }
        } catch(pollErr) {
            uiLog('err', 'Poll render error: ' + (pollErr&&(pollErr.message||String(pollErr))));
        }
    }).finally(function(){S.polling=false;});
}
function fetchBeavers(){if(DLL_AVAILABLE===false)return;get('/api/beavers').then(function(b){S.beavers=b||[];S.beaversLoaded=true;if(S.tab==='population')render();}).catch(function(){});}

// ── Automation engine ─────────────────────────────────────────────────────────
function evalCondition(cond) {
    if(cond.type==='adapter'){var a=S.adapters.find(function(x){return x.name===cond.adapterName;});if(!a)return false;return(cond.adapterState==='on'&&a.state===true)||(cond.adapterState==='off'&&a.state===false);}
    if(cond.type==='lever'){var lv=S.levers.find(function(x){return x.name===cond.leverName;});if(!lv)return false;return(cond.leverState==='on'&&lv.state===true)||(cond.leverState==='off'&&lv.state===false);}
    if(cond.type==='sensor'){var sn=S.sensors.find(function(x){return x.name===cond.sensorName;});if(!sn)return false;return(cond.sensorState==='on'&&sn.isOn===true)||(cond.sensorState==='off'&&sn.isOn===false);}
    if(cond.type==='gamestate'){
        if(!S.gameState)return false;
        var gs=S.gameState;
        // weatherId is the reliable source (new backend); isDrought/isBadtide are fallbacks
        var wId=(gs.weatherId||'').toLowerCase();
        if(cond.field==='isDrought')  return wId==='drought'||!!gs.isDrought;
        if(cond.field==='isBadtide')  return wId==='badtide'||!!gs.isBadtide;
        if(cond.field==='isHazardous')return !!gs.weatherIsHazardous||!!gs.isHazardous||(wId!==''&&wId!=='temperate'&&!!gs.weatherIsHazardous!==false);
        return !!gs[cond.field];
    }
    if(cond.type==='time'){if(!S.gameState)return false;var h=S.gameState.timeOfDayHours,fr=cond.fromHour,to=cond.toHour;return fr<=to?(h>=fr&&h<to):(h>=fr||h<to);}
    if(cond.type==='population'){if(!S.population)return false;var val=S.population[cond.field];if(val===undefined)return false;var t=cond.threshold;switch(cond.op){case'gt':return val>t;case'gte':return val>=t;case'lt':return val<t;case'lte':return val<=t;case'eq':return val===t;}}
    if(cond.type==='duration'){var da=S.adapters.find(function(x){return x.name===cond.adapterName;});var dOn=da&&da.state===true;if(!dOn){cond._startTime=null;return false;}if(!cond._startTime)cond._startTime=Date.now();return(Date.now()-cond._startTime)>=(cond.durationSec||10)*1000;}
    if(cond.type==='popchange'){if(!S.population)return false;var pcv=S.population[cond.field];if(pcv===undefined)return false;var pcPrev=cond._prevValue;cond._prevValue=pcv;if(pcPrev===undefined)return false;return cond.direction==='growing'?(pcv>pcPrev):(pcv<pcPrev);}
    if(cond.type==='daycycle'){if(!S.gameState)return false;var dday=S.gameState.dayNumber;if(dday===undefined)return false;var dt=cond.threshold||1;switch(cond.op){case'gt':return dday>dt;case'gte':return dday>=dt;case'lt':return dday<dt;case'lte':return dday<=dt;case'eq':return dday===dt;}}
    if(cond.type==='sensor_value'){var svn=S.sensors.find(function(x){return x.name===cond.sensorName;});if(!svn)return false;if(svn.value===null||svn.value===undefined)return svn.isOn===true;var sv=parseFloat(svn.value),svt=parseFloat(cond.threshold)||0;switch(cond.op){case'gt':return sv>svt;case'gte':return sv>=svt;case'lt':return sv<svt;case'lte':return sv<=svt;case'eq':return Math.abs(sv-svt)<0.0001;}return false;}
    return false;
}
// Deduplication: prevents same lever/state being POSTed repeatedly within DEDUP_MS.
// This stops "direct" mode from fighting manual lever toggles — the guard
// lever.state===wantOn works for one cycle but the poll merge can reset lever.state
// before the HTTP response arrives, defeating it on the next cycle.
var _leverLastAction = {};
var DEDUP_MS = 4000;

function applyActions(actions, _ruleName){(actions||[]).forEach(function(action){
    var lever=S.levers.find(function(l){return l.name===action.leverName;});if(!lever)return;
    if(action.leverState==='color'){
        var hex=(action.leverColor||'ffffff').replace(/^#/,'').slice(0,6).toLowerCase();
        if(lever.colorUrl){
            post(lever.colorUrl.replace('{color}',hex))
                .then(function(r){if(r.ok)uiLog('rule','Lever "'+action.leverName+'" \u2192 color #'+hex+(_ruleName?' ['+_ruleName+']':''));else uiLog('err','Color HTTP '+r.status+' ['+action.leverName+']');})
                .catch(function(e){uiLog('err','Color error: '+(e.message||e));});
        }
        return;
    }
    var wantOn=action.leverState==='on';
    if(lever.state===wantOn)return;
    var dedupKey=action.leverName+'_'+(wantOn?'on':'off');
    if(Date.now()-(_leverLastAction[dedupKey]||0)<DEDUP_MS)return;
    _leverLastAction[dedupKey]=Date.now();
    post(wantOn?lever.switchOnUrl:lever.switchOffUrl).then(function(r){if(r.ok){lever.state=wantOn;uiLog('rule','Lever "'+action.leverName+'" \u2192 '+action.leverState.toUpperCase()+(_ruleName?' ['+_ruleName+']':''));}else{uiLog('err','Lever "'+action.leverName+'" toggle HTTP '+r.status+(_ruleName?' ['+_ruleName+']':''));showErr('Rule "'+action.leverName+'": HTTP '+r.status);}}).catch(function(e){uiLog('err','Lever "'+action.leverName+'" error: '+(e.message||e));showErr('Rule "'+action.leverName+'": '+e.message);});
});}
function runAutomation() {
    var now=Date.now();
    S.rules.filter(function(r){return r.enabled;}).forEach(function(rule){
        if(rule.mode==='simple'){
            var sim=rule.simple;if(!sim||!sim.conditions||!sim.conditions.length)return;
            var triggered=sim.conditionMode==='or'?sim.conditions.some(evalCondition):sim.conditions.every(evalCondition);
            // Auto-reset latch: evaluate reset conditions if defined
            if(sim.resetConditions&&sim.resetConditions.length){
                var resetTriggered=sim.resetCondMode==='or'?sim.resetConditions.some(evalCondition):sim.resetConditions.every(evalCondition);
                if(resetTriggered&&sim._latchFired){sim._latchFired=false;uiLog('rule','['+rule.name+'] Latch auto-reset');}
            }
            var ft=sim.functionType||'direct';
            // "trigger" = rising-edge only (fires once when condition becomes true)
            // "direct"  = enforce every cycle while true (legacy behaviour)
            if(ft==='trigger'){
                if(triggered&&!sim._prevTriggered){
                    uiLog('rule','['+rule.name+'] Trigger \u2014 rising edge');
                    applyActions(sim.actions,rule.name);
                }
                sim._prevTriggered=triggered;
                return;
            }
            if(ft==='direct'){
                if(triggered) applyActions(sim.actions, rule.name);
                sim._prevTriggered=triggered;
                return;
            }
            if(ft==='timer'){
                if(!triggered){sim._timerStart=null;sim._prevTriggered=false;return;}
                if(!sim._timerStart)sim._timerStart=now;
                if((now-sim._timerStart)/1000>=(sim.timerSeconds||0)){
                    uiLog('rule','['+rule.name+'] Timer elapsed ('+sim.timerSeconds+'s) \u2014 firing');
                    applyActions(sim.actions,rule.name);sim._timerStart=null;
                }
                return;
            }
            if(ft==='latch'){
                if(triggered&&!sim._latchFired){
                    sim._latchFired=true;
                    uiLog('rule','['+rule.name+'] Latch set \u2014 firing');
                    applyActions(sim.actions,rule.name);
                }
                if(!triggered)sim._latchFired=false;
            }
            return;
        }
        if(rule.mode==='code'){
            var _prevCodeErr=rule._lastError;
            runCodeRule(rule);
            if(rule._lastError&&rule._lastError!==_prevCodeErr)
                uiLog('err','[Code:"'+rule.name+'"] '+rule._lastError);
            return;
        }
        if(rule.mode==='fbd'){
            var _prevFbdErr=rule._lastError;
            runFbdRule(rule);
            if(rule._lastError&&rule._lastError!==_prevFbdErr)
                uiLog('err','[FBD:"'+rule.name+'"] '+rule._lastError);
            return;
        }
    });
}

// ── Code rule execution ───────────────────────────────────────────────────────
var CODE_LOG_MAX=80;
function codeLog(ruleId,msg,isErr){if(!S.codeLogs[ruleId])S.codeLogs[ruleId]=[];var now=new Date(),ts=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0')+':'+now.getSeconds().toString().padStart(2,'0');S.codeLogs[ruleId].push({time:ts,msg:String(msg),isErr:!!isErr});if(S.codeLogs[ruleId].length>CODE_LOG_MAX)S.codeLogs[ruleId].shift();}
function runCodeRule(rule) {
    var script=rule.code&&rule.code.script;if(!script||!script.trim())return;
    var ctx={adapters:S.adapters.slice(),levers:S.levers.slice(),sensors:S.sensors.slice(),gameState:S.gameState||null,population:S.population||null};
    function setLever(name,state){applyActions([{leverName:name,leverState:(state===true||state==='on')?'on':'off'}]);}
    function log(msg){codeLog(rule.id,msg,false);}
    try{/*jshint evil:true*/var fn=new Function('adapters','levers','sensors','gameState','population','setLever','log',script);fn(ctx.adapters,ctx.levers,ctx.sensors,ctx.gameState,ctx.population,setLever,log);rule._lastError=null;}
    catch(e){codeLog(rule.id,e.message||String(e),true);rule._lastError=e.message||String(e);}
}
function updateCodeLogPanel(){var rule=S.editingRuleId&&S.rules.find(function(r){return r.id===S.editingRuleId;});if(!rule||rule.mode!=='code')return;var el=document.getElementById('tac-code-log');if(!el)return;el.innerHTML=renderCodeLogLines(rule.id);el.scrollTop=el.scrollHeight;}
function renderCodeLogLines(ruleId){var lines=S.codeLogs[ruleId]||[];if(!lines.length)return'<span class="text-muted" style="font-size:.78rem;font-family:monospace">No output yet \u2014 run the rule or call log() in your script.</span>';return lines.map(function(l){return'<div class="tac-log-line'+(l.isErr?' tac-log-err':'')+'"><span class="tac-log-time">'+esc(l.time)+'</span>'+(l.isErr?'\u274c ':'')+esc(l.msg)+'</div>';}).join('');}

// ── Render ────────────────────────────────────────────────────────────────────
function render() {
    var el=document.getElementById('tac-content');if(!el)return;
    var dllWarn=DLL_AVAILABLE===false?'<div class="alert alert-warning d-flex align-items-center gap-2 mx-3 mt-3 mb-0 py-2"><span class="fs-5">\u26a0\ufe0f</span><span><strong>DLL not loaded</strong> \u2014 Game state, population, and beaver data unavailable. Levers, adapters, and automation work normally.</span></div>':'';
    switch(S.tab){
        case'dashboard': el.innerHTML=dllWarn+renderDashboard(); break;
        case'levers':    el.innerHTML=renderLevers();            break;
        case'adapters':  el.innerHTML=renderAdapters();          break;
        case'sensors':   el.innerHTML=dllWarn+renderSensors();   break;
        case'population':el.innerHTML=dllWarn+renderPopulation();break;
        case'automation':
            el.innerHTML=renderAutomation();
            if(S.automationView==='edit'){var er=S.rules.find(function(r){return r.id===S.editingRuleId;});if(er&&er.mode==='fbd')attachFbdCanvas(er);}
            break;
        case'logs':      el.innerHTML=renderLogs();               break;
    }
}

// ── Dashboard ─────────────────────────────────────────────────────────────────
function renderDashboard() {
    var gs=S.gameState,pop=S.population;
    function statCard(label,val,color){return'<div class="col-auto"><div class="card bg-'+color+' bg-opacity-25 text-center px-3 py-2" style="min-width:72px"><div class="fs-5 fw-bold">'+esc(String(val))+'</div><div class="small text-muted">'+esc(label)+'</div></div></div>';}
    var gsHtml;
    if(!gs){gsHtml='<div class="card bg-body-secondary h-100"><div class="card-body text-center text-muted py-4"><div class="fs-2 mb-2">\uD83C\uDF0D</div><div>Load a save to see game state</div>'+(DLL_AVAILABLE===false?'<div class="small mt-1 text-warning">Requires DLL mod</div>':'')+'</div></div>';}
    else{
        // weatherId is the backend's best guess; isDrought/isBadtide are fallbacks.
        // When the backend can't identify the specific hazard (CurrentCycleHazardousWeather
        // returns null), weatherId stays "Temperate" while isHazardous/weatherIsHazardous=true.
        // In that case, label it "Hazardous" rather than showing "⚠ Temperate".
        var wId=(gs.weatherId||'').toLowerCase();
        var isDrought=wId==='drought'||!!gs.isDrought;
        var isBadtide=wId==='badtide'||!!gs.isBadtide;
        var isHazardous=!!gs.weatherIsHazardous||!!gs.isHazardous;
        // weatherId is unreliable when it says "Temperate" but isHazardous=true
        var unknownHazard=isHazardous&&!isDrought&&!isBadtide;
        // Build a clean display label
        var weatherLabel=isDrought?'Drought':isBadtide?'Badtide':unknownHazard?'Hazardous':(gs.weatherId&&gs.weatherId!=='Temperate'?esc(gs.weatherId):'Temperate');
        var daysLeft=gs.weatherDaysRemaining>0?' <span class="text-muted" style="font-size:.75em">('+gs.weatherDaysRemaining+'d left)</span>':'';
        var wBadge=isDrought
            ?'<span class="badge bg-warning text-dark">\uD83C\uDF35 Drought</span>'
            :isBadtide
            ?'<span class="badge bg-danger">\u2620\ufe0f Badtide</span>'
            :unknownHazard
            ?'<span class="badge bg-warning text-dark">\u26a0\ufe0f Hazardous</span>'
            :'<span class="badge bg-success">\u2600\ufe0f Temperate</span>';
        gsHtml='<div class="card bg-body-secondary h-100"><div class="card-body"><h6 class="card-title text-muted mb-2">\uD83C\uDF0D Game State</h6><table class="table table-sm table-borderless mb-0 small"><tbody><tr><td class="text-muted pe-3">Cycle</td><td>'+gs.cycleNumber+'</td></tr><tr><td class="text-muted pe-3">Day</td><td>'+gs.dayNumber+'</td></tr><tr><td class="text-muted pe-3">Time</td><td>'+gs.timeOfDayHours+'h &mdash; '+esc(gs.dayStage)+'</td></tr><tr><td class="text-muted pe-3">Weather</td><td>'+wBadge+daysLeft+'</td></tr></tbody></table></div></div>';
    }
    var popHtml;
    if(!pop){popHtml='<div class="card bg-body-secondary h-100"><div class="card-body text-center text-muted py-4"><div class="fs-2 mb-2">\uD83E\uDDB8</div><div>Load a save to see population</div></div></div>';}
    else{popHtml='<div class="card bg-body-secondary h-100"><div class="card-body"><h6 class="card-title text-muted mb-2">\uD83E\uDDB8 Population</h6><div class="row g-2 row-cols-auto">'+statCard('Total',pop.totalBeavers,'primary')+statCard('Adults',pop.adults,'success')+statCard('Children',pop.children,'info')+statCard('Idle',pop.unemployed,pop.unemployed>0?'warning':'secondary')+statCard('Homeless',pop.homeless,pop.homeless>0?'warning':'secondary')+statCard('Injured',pop.injured,pop.injured>0?'danger':'secondary')+statCard('Contam.',pop.contaminated,pop.contaminated>0?'danger':'secondary')+'</div></div></div>';}
    var lvOn=S.levers.filter(function(l){return l.state;}).length;
    var adOn=S.adapters.filter(function(a){return a.state;}).length;
    var rOn=S.rules.filter(function(r){return r.enabled;}).length;
    // Per-mode active counts
    var rSimple=S.rules.filter(function(r){return r.enabled&&r.mode==='simple';}).length;
    var rFbd   =S.rules.filter(function(r){return r.enabled&&r.mode==='fbd';}).length;
    var rCode  =S.rules.filter(function(r){return r.enabled&&r.mode==='code';}).length;
    var modeChips='';
    if(rSimple)modeChips+='<span class="badge tac-mode-simple">S:'+rSimple+'</span>';
    if(rFbd)   modeChips+='<span class="badge tac-mode-fbd">F:'+rFbd+'</span>';
    if(rCode)  modeChips+='<span class="badge tac-mode-code">C:'+rCode+'</span>';
    function miniCard(icon,title,chips){return'<div class="card bg-body-secondary"><div class="card-body py-2 px-3"><div class="d-flex align-items-center gap-2"><span class="fs-5">'+icon+'</span><span class="fw-semibold small">'+esc(title)+'</span><div class="ms-auto d-flex gap-1 flex-wrap">'+chips+'</div></div></div></div>';}
    var _sensors=Array.isArray(S.sensors)?S.sensors:[];
    var snOn=_sensors.filter(function(s){return s.isOn;}).length;
    var summaryHtml='<div class="d-flex flex-column gap-2">'+miniCard('\uD83C\uDF9A','Levers ('+S.levers.length+')','<span class="badge bg-success">'+lvOn+' ON</span><span class="badge bg-secondary">'+(S.levers.length-lvOn)+' OFF</span>')+miniCard('\uD83D\uDCE1','Adapters ('+S.adapters.length+')','<span class="badge bg-success">'+adOn+' ON</span><span class="badge bg-secondary">'+(S.adapters.length-adOn)+' OFF</span>')+(_sensors.length?miniCard('\uD83D\uDCF1','Sensors ('+_sensors.length+')','<span class="badge bg-success">'+snOn+' ON</span><span class="badge bg-secondary">'+(_sensors.length-snOn)+' OFF</span>'):'')+ miniCard('\u26a1','Automation','<span class="badge bg-primary">'+rOn+' active</span>'+modeChips+'<span class="badge bg-secondary">'+S.rules.length+' total</span>')+'</div>';
    return'<div class="container-fluid py-3"><div class="row g-3"><div class="col-lg-4">'+gsHtml+'</div><div class="col-lg-4">'+popHtml+'</div><div class="col-lg-4">'+summaryHtml+'</div></div></div>';
}

// ── Levers ────────────────────────────────────────────────────────────────────
function renderLevers(){
    if(!S.levers.length)return'<div class="text-center text-muted py-5 fs-5">No HTTP Levers found.<br><small class="fs-6">Place HTTP Lever buildings in your settlement.</small></div>';
    var rows=S.levers.map(function(l){
        var ln=esc(l.name);
        var safeId='lc_'+l.name.replace(/[^a-zA-Z0-9]/g,'_');
        var stateHtml=l.isSpringReturn?'<span class="tac-spr">SPR</span>':l.state?'<span class="tac-on">ON</span>':'<span class="tac-off">OFF</span>';
        // Color picker — native wheel + hex text input side by side
        var colorPicker=l.colorUrl
            ? '<span class="d-inline-flex align-items-center gap-1 ms-2">'
            + '<input type="color" id="'+safeId+'" value="#ff0000"'
            + ' style="width:28px;height:28px;padding:1px;border:1px solid rgba(255,255,255,.25);border-radius:.25rem;background:transparent;cursor:pointer"'
            + ' oninput="document.getElementById(\''+safeId+'_hex\').value=this.value.slice(1)">'
            + '<input type="text" id="'+safeId+'_hex" value="ff0000" maxlength="6"'
            + ' style="width:62px;font-size:.75rem;font-family:monospace;background:#1a1f2e;border:1px solid rgba(255,255,255,.2);border-radius:.25rem;color:#e6edf3;padding:.1rem .3rem"'
            + ' oninput="if(this.value.length===6)document.getElementById(\''+safeId+'\').value=\'#\'+this.value">'
            + '<button type="button" style="font-size:.75rem;padding:.15rem .45rem;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);border-radius:.25rem;color:#e6edf3;cursor:pointer"'
            + ' onclick="TAC.color(\''+ln+'\',document.getElementById(\''+safeId+'_hex\').value)">Apply</button>'
            + '</span>'
            : '';
        return'<tr><td class="align-middle fw-semibold">'+ln+'</td>'
            +'<td class="text-center align-middle">'+stateHtml+'</td>'
            +'<td class="align-middle">'
            +'<button type="button" class="btn btn-sm btn-success me-1" onclick="TAC.on(\''+ln+'\')">On</button>'
            +'<button type="button" class="btn btn-sm btn-secondary me-1" onclick="TAC.off(\''+ln+'\')">Off</button>'
            +colorPicker
            +'</td></tr>';
    }).join('');
    return'<div class="container-fluid py-3"><div class="d-flex justify-content-center"><table class="table table-hover table-sm w-auto"><thead><tr><th>Lever</th><th class="text-center">State</th><th>Actions</th></tr></thead><tbody>'+rows+'</tbody></table></div></div>';
}
// ── Adapters ──────────────────────────────────────────────────────────────────
function renderAdapters(){if(!S.adapters.length)return'<div class="text-center text-muted py-5 fs-5">No HTTP Adapters found.<br><small class="fs-6">Place HTTP Adapter buildings in your settlement.</small></div>';var rows=S.adapters.map(function(a){return'<tr><td class="align-middle fw-semibold">'+esc(a.name)+'</td><td class="text-center align-middle">'+(a.state?'<span class="tac-on">ON</span>':'<span class="tac-off">OFF</span>')+'</td></tr>';}).join('');return'<div class="container-fluid py-3"><div class="d-flex justify-content-center"><table class="table table-hover table-sm w-auto"><thead><tr><th>Adapter</th><th class="text-center">State</th></tr></thead><tbody>'+rows+'</tbody></table></div></div>';}

// ── Sensors ────────────────────────────────────────────────────────────────────
// Format fractional hours (e.g. 5.625) as 24h HH:MM string ("05:37")
function fmtTime(v){var h=Math.floor(v),m=Math.floor((v-h)*60);return('0'+h).slice(-2)+':'+('0'+m).slice(-2);}
// Sensor type → display icon mapping
var SENSOR_ICONS={FlowSensor:'\uD83C\uDF0A',DepthSensor:'\uD83D\uDCCF',ContaminationSensor:'\u2620\ufe0f',Chronometer:'\u23F0',WeatherStation:'\uD83C\uDF27\ufe0f',PowerMeter:'\u26A1',PopulationCounter:'\uD83E\uDDB8',ResourceCounter:'\uD83D\uDCE6',ScienceCounter:'\uD83D\uDD2C',Memory:'\uD83D\uDCBE',Relay:'\uD83D\uDD17',Unknown:'\u2753'};
function renderSensors(){
    var slist=Array.isArray(S.sensors)?S.sensors:[];
    if(!slist.length)return'<div class="text-center text-muted py-5 fs-5">\uD83D\uDCF1 No sensors found.<br><small class="fs-6">Place automation sensor buildings (Flow Sensor, Depth Sensor, etc.) in your settlement.</small></div>';
    var rows=slist.map(function(s){
        var icon=SENSOR_ICONS[s.type]||SENSOR_ICONS.Unknown;
        var typeLabel=(s.type||'Unknown').replace(/([A-Z])/g,' $1').trim();
        var opSym={'gt':'>','gte':'\u2265','lt':'<','lte':'\u2264','eq':'='};
        var valStr=s.value!==null&&s.value!==undefined
            ?('<span class="fw-semibold">'+(s.unit==='HH:MM'?fmtTime(s.value):Number(s.value).toFixed(2))+'</span>'+(s.unit&&s.unit!=='HH:MM'?'<span class="text-muted ms-1" style="font-size:.8em">'+esc(s.unit)+'</span>':''))
            :'<span class="text-muted small">\u2014</span>';
        var threshStr=(s.threshold!==null&&s.threshold!==undefined&&s.operator)
            ?('<span class="text-muted small">'+(opSym[s.operator]||s.operator)+' '+Number(s.threshold).toFixed(2)+' '+esc(s.unit||'')+'</span>')
            :'<span class="text-muted small">\u2014</span>';
        var badge=s.isOn?'<span class="tac-on">ON</span>':'<span class="tac-off">OFF</span>';
        return'<tr>'
            +'<td class="align-middle" style="font-size:1.1em">'+icon+'</td>'
            +'<td class="align-middle fw-semibold">'+esc(s.name)+'</td>'
            +'<td class="align-middle text-muted small">'+esc(typeLabel)+'</td>'
            +'<td class="align-middle text-center">'+valStr+'</td>'
            +'<td class="align-middle text-center">'+threshStr+'</td>'
            +'<td class="align-middle text-center">'+badge+'</td>'
            +'</tr>';
    }).join('');
    return'<div class="container-fluid py-3">'
        +'<table class="table table-hover table-sm"><thead><tr><th></th><th>Name</th><th>Type</th><th class="text-center">Value</th><th class="text-center">Fires when</th><th class="text-center">Signal</th></tr></thead>'
        +'<tbody>'+rows+'</tbody></table>'
        +'<div class="text-muted small mt-2">\u2139\ufe0f Signal is ON when the in-game threshold condition is met. Use <strong>Sensor value</strong> condition type in rules to compare the numeric reading directly.</div>'
        +'</div>';
}

// ── Population
// ── Population ────────────────────────────────────────────────────────────────
function renderPopulation(){var pop=S.population;if(!pop)return'<div class="text-center text-muted py-5">Population data unavailable.<br><small>Requires the HTTPAutomation DLL mod to be loaded.</small></div>';function statCard(label,val,color){return'<div class="col-auto"><div class="card bg-'+color+' bg-opacity-25 text-center px-3 py-2" style="min-width:72px"><div class="fs-5 fw-bold">'+esc(String(val))+'</div><div class="small text-muted">'+esc(label)+'</div></div></div>';}var summary='<div class="row g-2 row-cols-auto justify-content-center mb-4">'+statCard('Total',pop.totalBeavers,'primary')+statCard('Adults',pop.adults,'success')+statCard('Children',pop.children,'info')+statCard('Idle',pop.unemployed,pop.unemployed>0?'warning':'secondary')+statCard('Homeless',pop.homeless,pop.homeless>0?'warning':'secondary')+statCard('Injured',pop.injured,pop.injured>0?'danger':'secondary')+statCard('Contam.',pop.contaminated,pop.contaminated>0?'danger':'secondary')+'</div>';var beaverHtml;if(!S.beaversLoaded){beaverHtml='<div class="text-center text-muted py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading beavers...</div>';}else if(!S.beavers.length){beaverHtml='<div class="text-center text-muted py-3">No beavers found.</div>';}else{var cards=S.beavers.map(function(b){var badges='';if(!b.isAdult)badges+='<span class="badge bg-info me-1">Child</span>';if(!b.hasJob)badges+='<span class="badge bg-warning text-dark me-1">Idle</span>';if(!b.hasHome)badges+='<span class="badge bg-warning text-dark me-1">Homeless</span>';if(b.isInjured)badges+='<span class="badge bg-danger me-1">Injured</span>';if(b.isContaminated)badges+='<span class="badge bg-danger me-1">Contam.</span>';function bar(val,icon){var pct=Math.round(Math.max(0,Math.min(1,(val+1)/2))*100);var c=pct>60?'success':pct>30?'warning':'danger';return'<div class="d-flex align-items-center gap-1 mb-1"><span style="width:1.1em;font-size:.8em">'+icon+'</span><div class="progress flex-grow-1" style="height:5px"><div class="progress-bar bg-'+c+'" style="width:'+pct+'%"></div></div><span class="text-muted" style="font-size:.65em;width:3.2em">'+val.toFixed(2)+'</span></div>';}var sub=(b.isAdult?'Adult':'Child')+' \u00b7 Day '+b.ageInDays;if(b.workplace)sub+=' \u00b7 '+esc(b.workplace);return'<div class="col-sm-6 col-md-4 col-xl-3"><div class="card bg-body-secondary h-100"><div class="card-body card-sm"><div class="fw-semibold">'+esc(b.name)+'</div><div class="small text-muted mb-1">'+sub+'</div>'+(badges?'<div class="mb-1">'+badges+'</div>':'')+bar(b.hunger,'\uD83C\uDF5E')+bar(b.thirst,'\uD83D\uDCA7')+bar(b.sleep,'\uD83D\uDE34')+((b.hasJob&&b.isAdult)?'<button type="button" class="btn btn-outline-danger btn-sm mt-1 w-100" onclick="TAC.dismiss(\''+b.id+'\')">Dismiss</button>':'')+'</div></div></div>';}).join('');beaverHtml='<div class="row g-2">'+cards+'</div>';}return'<div class="container-fluid py-3">'+summary+beaverHtml+'</div>';}

// ── Automation ────────────────────────────────────────────────────────────────
function renderAutomation(){return S.automationView==='edit'?renderRuleEditor():renderRuleList();}
function modeBadgeHtml(mode){var l={simple:'Simple',fbd:'FBD',code:'Code'},c={simple:'tac-mode-simple',fbd:'tac-mode-fbd',code:'tac-mode-code'};return'<span class="badge '+(c[mode]||'bg-secondary')+'">'+(l[mode]||mode)+'</span>';}
function ruleDescription(r){if(r.mode==='simple'){var sim=r.simple,cond=sim&&sim.conditions&&sim.conditions[0],act=sim&&sim.actions&&sim.actions[0];var condStr=cond?(cond.type==='adapter'?(esc(cond.adapterName)+' is '+cond.adapterState.toUpperCase()):cond.type==='lever'?(esc(cond.leverName)+' is '+cond.leverState.toUpperCase()):cond.type==='sensor'?(esc(cond.sensorName)+' '+cond.sensorState.toUpperCase()):cond.type==='sensor_value'?(esc(cond.sensorName)+' '+(cond.op||'gte')+' '+(cond.threshold||0)):cond.type==='gamestate'?esc(cond.field):cond.type==='time'?('Time '+cond.fromHour+'\u2013'+cond.toHour+'h'):cond.type==='population'?(esc(cond.field)+' '+cond.op+' '+cond.threshold):'?'):'(no conditions)';var extra=(sim&&sim.conditions&&sim.conditions.length>1)?' <span class="text-muted">+'+(sim.conditions.length-1)+' more</span>':'';var actStr=act?('Set <strong>'+esc(act.leverName)+'</strong> '+act.leverState.toUpperCase()):'(no actions)';return condStr+extra+' \u2192 '+actStr;}if(r.mode==='code'){var lines=(r.code&&r.code.script||'').split('\n').filter(function(l){return l.trim()&&!l.trim().startsWith('//');}); return'<span class="text-muted fst-italic">'+(lines.length?lines.length+' line'+(lines.length>1?'s':'')+' of code':'Empty script')+'</span>';}if(r.mode==='fbd'){var nc=r.fbd&&r.fbd.nodes&&r.fbd.nodes.length;var thumb=r._fbdThumb?'<img src="'+r._fbdThumb+'" onclick="TAC._fbdOpenFullscreen(\''+esc(r.id)+'\')" style="height:38px;border-radius:3px;vertical-align:middle;margin-right:6px;border:1px solid rgba(255,255,255,.12);cursor:pointer" title="Click to open full-screen FBD editor">':'';return thumb+'<span class="text-muted fst-italic">'+(nc?nc+' node'+(nc>1?'s':''):'Empty diagram \u2014 right-click canvas to add nodes')+'</span>';}return'\u2014';}

function renderRuleList() {
    var warn='';
    if(!S.adapters.length)warn+='<div class="alert alert-warning py-2 mb-2 small">No HTTP Adapters in game \u2014 place HTTP Adapter buildings to use as triggers.</div>';
    if(!S.levers.length)  warn+='<div class="alert alert-warning py-2 mb-2 small">No HTTP Levers in game \u2014 place HTTP Lever buildings to control with rules.</div>';
    // Step 8: DLL warning for automation tab — conditions/FBD nodes needing DLL evaluate to false
    if(DLL_AVAILABLE===false)warn+='<div class="alert alert-secondary py-2 mb-2 small d-flex align-items-center gap-2"><span>\u26a0\ufe0f</span><span>DLL not loaded \u2014 conditions and FBD nodes that read game state or population will always evaluate to <strong>false</strong>. Adapter-based rules work normally.</span></div>';

    // Header with Export / Import buttons
    var header='<div class="d-flex align-items-center mb-2 gap-2">'
              + '<h5 class="mb-0 fw-semibold">\u26a1 Automation Rules</h5>'
              + '<div class="ms-auto d-flex gap-1">'
              + '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC.exportRules()" title="Export rules as JSON">\u2191 Export</button>'
              + '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC.toggleImport()" title="Import rules from JSON">\u2193 Import</button>'
              + '<button type="button" class="btn btn-sm btn-primary" onclick="TAC.newRule()">+ Add Rule</button>'
              + '</div></div>';

    // Import panel
    var importPanel='';
    if(S.showImport){
        importPanel='<div class="tac-import-box mb-3">'
                  + '<div class="text-muted small fw-semibold mb-1">IMPORT RULES FROM JSON</div>'
                  + '<div class="text-muted small mb-2">Paste exported JSON below. This will <strong>replace</strong> all current rules.</div>'
                  + '<textarea id="tac-import-ta" class="form-control form-control-sm bg-body-secondary border-secondary text-light mb-2" rows="4" style="font-family:Consolas,monospace;font-size:.78rem" placeholder=\'[{"id":"...","name":"...",...}]\'></textarea>'
                  + '<div class="d-flex gap-2">'
                  + '<button type="button" class="btn btn-sm btn-danger" onclick="TAC.importRules()">Replace all rules</button>'
                  + '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC.toggleImport()">Cancel</button>'
                  + '</div></div>';
    }

    if(!S.rules.length){return'<div class="container-fluid py-3">'+warn+header+importPanel+'<div class="card bg-body-secondary"><div class="card-body text-center text-muted py-5"><div class="fs-2 mb-2">\u26a1</div><div class="fw-semibold mb-1">No automation rules yet</div><div class="small mb-3">Rules let you automatically control levers based on adapter states, game conditions, and more.</div><button type="button" class="btn btn-sm btn-primary" onclick="TAC.newRule()">+ Add your first rule</button></div></div></div>';}

    var rows=S.rules.map(function(r,i){
        var id=esc(r.id),badge=modeBadgeHtml(r.mode),checked=r.enabled?' checked':'';
        var ftLabel='';if(r.mode==='simple'&&r.simple){if(r.simple.functionType==='timer')ftLabel=' <span class="badge bg-secondary">Timer</span>';if(r.simple.functionType==='latch')ftLabel=' <span class="badge bg-secondary">Latch</span>';}
        // Error badge
        var errBadge='';
        if(r._lastError)errBadge=' <span class="badge bg-danger" title="'+esc(r._lastError)+'">!</span>';
        else if(r.mode==='code'&&S.codeLogs[r.id]){var hasRecentErr=S.codeLogs[r.id].slice(-5).some(function(l){return l.isErr;});if(hasRecentErr)errBadge=' <span class="badge bg-danger" title="Recent script error">!</span>';}
        // ↑ ↓ arrows
        var upBtn=i>0?'<button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" style="line-height:1" onclick="TAC.moveRule(\''+id+'\',-1)" title="Move up">\u2191</button>':'<span style="display:inline-block;width:26px"></span>';
        var dnBtn=i<S.rules.length-1?'<button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" style="line-height:1" onclick="TAC.moveRule(\''+id+'\',1)" title="Move down">\u2193</button>':'<span style="display:inline-block;width:26px"></span>';
        return'<tr class="tac-rule-row align-middle">'
             +'<td style="width:2.5rem"><div class="form-check form-switch mb-0" style="min-height:0"><input class="form-check-input" type="checkbox" role="switch"'+checked+' onchange="TAC.toggleRule(\''+id+'\')"></div></td>'
             +'<td style="width:5.5rem">'+badge+ftLabel+errBadge+'</td>'
             +'<td class="fw-semibold" style="min-width:120px">'+esc(r.name)+'</td>'
             +'<td class="small text-muted">'+ruleDescription(r)+'</td>'
             +'<td style="width:8rem" class="text-end">'
             +upBtn+' '+dnBtn
             +' <button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC.editRule(\''+id+'\')" title="Edit">\u270f\ufe0f</button>'
             +' <button type="button" class="btn btn-sm btn-outline-danger"   onclick="TAC.delRule(\''+id+'\')" title="Delete">\u2715</button>'
             +'</td></tr>';
    }).join('');
    var table='<div class="card bg-body-secondary"><div class="card-body p-0"><table class="table table-sm table-dark table-borderless mb-0"><thead><tr class="border-bottom border-secondary"><th class="ps-3" style="width:2.5rem"></th><th style="width:5.5rem">Mode</th><th>Name</th><th>Description</th><th style="width:8rem"></th></tr></thead><tbody>'+rows+'</tbody></table></div></div>';
    return'<div class="container-fluid py-3">'+warn+header+importPanel+table+'</div>';
}

function renderRuleEditor() {
    var rule=S.rules.find(function(r){return r.id===S.editingRuleId;});if(!rule)return renderRuleList();
    var rid=esc(rule.id);
    function modeCard(value,label,desc){var active=rule.mode===value;return'<div class="col-md-4"><label class="card h-100 p-3 w-100" style="cursor:pointer;border:2px solid '+(active?'#0d6efd':'rgba(255,255,255,.1)')+';background:rgba(255,255,255,.04)"><input type="radio" name="ruleMode" value="'+value+'" class="d-none"'+(active?' checked':'')+' onchange="TAC._setMode(\''+rid+'\',\''+value+'\')"><div class="fw-semibold mb-1">'+modeBadgeHtml(value)+' '+label+'</div><div class="small text-muted">'+desc+'</div></label></div>';}
    var modeSection='<div class="mb-4"><div class="text-muted small fw-semibold mb-2">MODE</div><div class="row g-2">'+modeCard('simple','Simple','Conditions, function types (Direct / Timer / SR-Latch), and lever actions.')+modeCard('fbd','FBD','Visual function block diagram \u2014 place and wire input, logic, and output nodes.')+modeCard('code','Code','Write a JavaScript snippet that runs every poll cycle (~0.5 s).')+'</div></div>';
    var editorArea=rule.mode==='simple'?renderSimpleEditor(rule):rule.mode==='code'?renderCodeEditor(rule):renderFbdEditor(rule);
    // Show per-rule error in editor if present
    var ruleErr=rule._lastError?'<div class="alert alert-danger py-2 mb-3 small d-flex align-items-center gap-2"><span>\u274c</span><span><strong>Rule error:</strong> '+esc(rule._lastError)+'</span></div>':'';
    return'<div class="container-fluid py-3"><div class="d-flex align-items-center mb-4 gap-3"><button type="button" class="btn btn-sm btn-outline-secondary" onclick="TAC.cancelEdit()">\u2190 Back</button><h5 class="mb-0 fw-semibold">Edit Rule</h5></div><div class="mb-4"><div class="text-muted small fw-semibold mb-1">RULE NAME</div><input id="editRuleName" type="text" class="form-control bg-body-secondary border-secondary text-light" value="'+esc(rule.name)+'" placeholder="e.g. Night lighting" maxlength="80"></div>'+modeSection+ruleErr+'<div class="mb-4">'+editorArea+'</div><div class="d-flex gap-2 justify-content-end"><button type="button" class="btn btn-outline-secondary" onclick="TAC.cancelEdit()">Cancel</button><button type="button" class="btn btn-primary" onclick="TAC.saveEdit(\''+rid+'\')">Save Rule</button></div></div>';
}

// ── Latch reset condition builder ─────────────────────────────────────────────
function renderLatchControls(rule, rid) {
    var sim=rule.simple;
    var resetConds=sim.resetConditions||[];
    var condTypes=[['adapter','Adapter'],['lever','Lever'],['gamestate','Game state'],['time','Time'],['population','Population']];
    var addSel='<select class="form-select form-select-sm w-auto" onchange="TAC._addResetCond(\''+rid+'\',this.value);this.selectedIndex=0;"><option value="" disabled selected>+ Add reset condition\u2026</option>'+condTypes.map(function(t){return'<option value="'+t[0]+'">'+t[1]+'</option>';}).join('')+'</select>';
    var resetRows=resetConds.map(function(cond,ci){
        var controls='';
        if(cond.type==='adapter'){var adOpts=S.adapters.length?S.adapters.map(function(a){return'<option value="'+esc(a.name)+'"'+(cond.adapterName===a.name?' selected':'')+'>'+esc(a.name)+'</option>';}).join(''):'<option value="">—</option>';controls='<select class="form-select form-select-sm" style="max-width:160px" onchange="TAC._updateResetCond(\''+rid+'\','+ci+',\'adapterName\',this.value)">'+adOpts+'</select><span class="text-muted small mx-1">is</span><select class="form-select form-select-sm" style="max-width:80px" onchange="TAC._updateResetCond(\''+rid+'\','+ci+',\'adapterState\',this.value)"><option value="on"'+(cond.adapterState==='on'?' selected':'')+'>ON</option><option value="off"'+(cond.adapterState==='off'?' selected':'')+'>OFF</option></select>';}
        if(cond.type==='lever'){var lvOpts=S.levers.length?S.levers.map(function(l){return'<option value="'+esc(l.name)+'"'+(cond.leverName===l.name?' selected':'')+'>'+esc(l.name)+'</option>';}).join(''):'<option value="">—</option>';controls='<select class="form-select form-select-sm" style="max-width:160px" onchange="TAC._updateResetCond(\''+rid+'\','+ci+',\'leverName\',this.value)">'+lvOpts+'</select><span class="text-muted small mx-1">is</span><select class="form-select form-select-sm" style="max-width:80px" onchange="TAC._updateResetCond(\''+rid+'\','+ci+',\'leverState\',this.value)"><option value="on"'+(cond.leverState==='on'?' selected':'')+'>ON</option><option value="off"'+(cond.leverState==='off'?' selected':'')+'>OFF</option></select>';}
        if(cond.type==='gamestate'){var gsF=[['isDay','Daytime'],['isNight','Nighttime'],['isDrought','Drought'],['isBadtide','Badtide'],['weatherIsHazardous','Any Hazardous']];controls='<select class="form-select form-select-sm" style="max-width:200px" onchange="TAC._updateResetCond(\''+rid+'\','+ci+',\'field\',this.value)">'+gsF.map(function(f){return'<option value="'+f[0]+'"'+(cond.field===f[0]?' selected':'')+'>'+f[1]+'</option>';}).join('')+'</select>';}
        return'<div class="tac-cond-row d-flex align-items-center gap-2 p-2 mb-1 flex-wrap"><div class="d-flex align-items-center gap-1 flex-wrap">'+controls+'</div><button type="button" class="btn btn-sm btn-outline-danger ms-auto flex-shrink-0" onclick="TAC._removeResetCond(\''+rid+'\','+ci+')">\u2715</button></div>';
    }).join('');
    return '<div class="mt-2 border border-secondary rounded p-2" style="background:rgba(255,180,0,.05)">'
         + '<div class="d-flex align-items-center gap-2 mb-1"><span class="text-muted small fw-semibold">\u21ba AUTO-RESET WHEN</span><div class="ms-auto">'+addSel+'</div></div>'
         + (resetConds.length?resetRows:'<div class="text-muted small fst-italic py-1">No reset conditions \u2014 use the Reset Latch button manually.</div>')
         + '<div class="d-flex align-items-center gap-2 mt-2"><button type="button" class="btn btn-sm btn-outline-warning" onclick="TAC.resetLatch(\''+rid+'\')">Reset Latch now</button></div>'
         + '</div>';
}

// ── Simple mode editor ────────────────────────────────────────────────────────
function renderSimpleEditor(rule) {
    var sim=rule.simple,rid=esc(rule.id);
    var condTypes=[['adapter','Adapter state'],['lever','Lever state'],['sensor','Sensor signal'],['sensor_value','Sensor value'],['gamestate','Game state'],['time','Time of day'],['population','Population'],['duration','Adapter ON for N sec'],['popchange','Population rate'],['daycycle','Day of cycle']];
    var addCondSel='<select class="form-select form-select-sm w-auto" onchange="TAC._addCondition(\''+rid+'\',this.value);this.selectedIndex=0;"><option value="" disabled selected>+ Add condition\u2026</option>'+condTypes.map(function(t){return'<option value="'+t[0]+'">'+t[1]+'</option>';}).join('')+'</select>';
