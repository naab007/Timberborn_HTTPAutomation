        +stateSidebar
        +'<div style="flex:1;min-width:0">'
        +'<div class="d-flex align-items-center mb-1"><span class="text-muted small fw-semibold text-uppercase">Script</span>'
        +'<button type="button" class="btn btn-sm btn-outline-secondary ms-auto py-0 px-2" style="font-size:.75rem" onclick="TAC._copyForAI(\''+rid+'\')">\uD83D\uDCCB Copy for AI</button>'
        +'</div>'
        +'<textarea id="tac-code-textarea" class="tac-code-area" rows="14" oninput="TAC._saveCode(\''+rid+'\')" spellcheck="false" autocorrect="off" autocapitalize="off">'+esc(script)+'</textarea>'
        +'<div class="d-flex align-items-center mb-1 mt-3"><span class="text-muted small fw-semibold text-uppercase">\uD83D\uDDA5\ufe0f Console</span><button type="button" class="btn btn-sm btn-outline-secondary ms-auto py-0 px-2" style="font-size:.75rem" onclick="TAC._clearLog(\''+rid+'\')">Clear</button></div>'
