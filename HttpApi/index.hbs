    html+='<button type="button" class="btn btn-sm btn-outline-danger w-100 mt-2" style="font-size:.75rem;padding:.15rem" onclick="TAC._fbdDeleteNode(\''+rid+'\',\''+nid+'\')">\u2715 Delete Node</button>';
    return html;
}

// ── FBD engine ────────────────────────────────────────────────────────────────
function runFbdRule(rule) {
    if(!rule.fbd||!rule.fbd.nodes.length)return;
    try {
        var nodes=rule.fbd.nodes,edges=rule.fbd.edges,signals={};
        var inDeg={};nodes.forEach(function(n){inDeg[n.id]=0;});edges.forEach(function(e){inDeg[e.toNodeId]=(inDeg[e.toNodeId]||0)+1;});
        var queue=nodes.filter(function(n){return!inDeg[n.id];}).map(function(n){return n.id;}),order=[];
        while(queue.length){var nid=queue.shift();order.push(nid);edges.filter(function(e){return e.fromNodeId===nid;}).forEach(function(e){inDeg[e.toNodeId]--;if(!inDeg[e.toNodeId])queue.push(e.toNodeId);});}
        var now=Date.now();
        order.forEach(function(nid){
            var node=nodes.find(function(n){return n.id===nid;});if(!node)return;
            var def=FBD_DEFS[node.type];if(!def)return;var p=node.params||{};
            function getIn(pin){var edge=edges.find(function(e){return e.toNodeId===nid&&e.toPin===pin;});if(!edge)return false;return!!signals[edge.fromNodeId+'_'+edge.fromPin];}
            var out=false;
            switch(node.type){
                case'INPUT_ADAPTER':{var a=S.adapters.find(function(x){return x.name===p.adapterName;});out=a?(p.adapterState==='on'?a.state===true:a.state===false):false;break;}
                case'INPUT_LEVER':{var lv=S.levers.find(function(x){return x.name===p.leverName;});out=lv?(p.leverState==='on'?lv.state===true:lv.state===false):false;break;}
                case'INPUT_SENSOR':{var sn=S.sensors.find(function(x){return x.name===p.sensorName;});out=sn?(p.sensorState==='on'?sn.isOn===true:sn.isOn===false):false;break;}
                case'INPUT_GAMESTATE':{if(!S.gameState)break;var wId=(S.gameState.weatherId||'').toLowerCase();if(p.field==='isDrought'){out=wId==='drought'||!!S.gameState.isDrought;}else if(p.field==='isBadtide'){out=wId==='badtide'||!!S.gameState.isBadtide;}else if(p.field==='isHazardous'||p.field==='weatherIsHazardous'){out=!!S.gameState.weatherIsHazardous||!!S.gameState.isHazardous;}else{out=!!S.gameState[p.field];}break;}
                case'INPUT_TIME':{if(!S.gameState)break;var h=S.gameState.timeOfDayHours,fr=p.fromHour||0,to=p.toHour||12;out=fr<=to?(h>=fr&&h<to):(h>=fr||h<to);break;}
                case'INPUT_POPULATION':case'LOGIC_COMPARE':{if(!S.population)break;var val=S.population[p.field];if(val===undefined)break;var thr=p.threshold||0;switch(p.op){case'gt':out=val>thr;break;case'gte':out=val>=thr;break;case'lt':out=val<thr;break;case'lte':out=val<=thr;break;case'eq':out=val===thr;break;}break;}
                case'ALWAYS_HIGH': out=true;break;
                case'ALWAYS_LOW':  out=false;break;
                case'LOGIC_AND':   out=getIn('A')&&getIn('B');break;
                case'LOGIC_OR':    out=getIn('A')||getIn('B');break;
                case'LOGIC_NAND':  out=!(getIn('A')&&getIn('B'));break;
                case'LOGIC_NOR':   out=!(getIn('A')||getIn('B'));break;
                case'LOGIC_NOT':   out=!getIn('IN');break;
                case'LOGIC_TIMER':{var inSig=getIn('IN');if(!inSig){node._timerStart=null;out=false;}else{if(!node._timerStart)node._timerStart=now;out=(now-node._timerStart)>=(p.preset||10)*1000;}break;}
                case'LOGIC_TOF':{// Off Delay: HIGH immediately on IN=true; stays HIGH for preset ms after IN goes false
                    var inSig=getIn('IN');
                    if(inSig){node._tofStart=null;out=true;}
                    else if(!node._tofStart){node._tofStart=now;out=true;}
                    else{out=(now-node._tofStart)<(p.preset||10)*1000;}
                    break;}
                case'LOGIC_TP':{// Pulse: fixed-length pulse on rising edge of IN
                    var inSig=getIn('IN');
                    if(inSig&&!node._prevIn){node._pulseStart=now;}
                    node._prevIn=inSig;
                    out=!!(node._pulseStart)&&(now-node._pulseStart)<(p.preset||5)*1000;
                    if(!out&&node._pulseStart&&(now-node._pulseStart)>=(p.preset||5)*1000)node._pulseStart=null;
                    break;}
                case'LOGIC_GEN':{// Gated oscillator — cycles only while IN is HIGH
                    var genIn=getIn('IN');
                    if(!genIn){node._genStart=null;out=false;break;}
                    if(!node._genStart)node._genStart=now;
                    var period=((p.onTime||5)+(p.offTime||5))*1000;
                    var phase=(now-node._genStart)%period;
                    out=phase<(p.onTime||5)*1000;
                    break;}
                case'LOGIC_CTU':{// Up counter: count rising edges on CU, reset on R, Q=count>=preset
                    var cu=getIn('CU'),rst=getIn('R');
                    if(rst){node._count=0;}
                    else if(cu&&!node._prevCU){node._count=(node._count||0)+1;}
                    node._prevCU=cu;
                    out=(node._count||0)>=(p.preset||5);
                    break;}
                case'LOGIC_RTC':{// Real-Time Clock window using browser time
                    var d=new Date(),h=d.getHours()+d.getMinutes()/60;
                    var fr=p.fromHour!==undefined?p.fromHour:8,to=p.toHour!==undefined?p.toHour:18;
                    out=fr<=to?(h>=fr&&h<to):(h>=fr||h<to);
                    break;}
                case'LOGIC_SRLATCH':{var Si=getIn('S'),Ri=getIn('R');if(Ri)node._latchQ=false;if(Si)node._latchQ=true;out=!!node._latchQ;break;}
                case'OUTPUT_LEVER':{var inVal=getIn('IN');
                    if(inVal&&p.leverName){
                        // IN is HIGH — apply the configured action (ON or OFF)
                        applyActions([{leverName:p.leverName,leverState:p.leverState||'on'}]);
                    } else if(!inVal&&p.leverName&&p.springReturn!==false){
                        // IN is LOW and spring-return enabled — send inverse state
                        var inverseState=(p.leverState==='on')?'off':'on';
                        applyActions([{leverName:p.leverName,leverState:inverseState}]);
                    }
                    out=inVal;break;}
            }
            def.outputs.forEach(function(pin){signals[nid+'_'+pin]=out;});
            def.inputs.forEach(function(pin){signals[nid+'_in_'+pin]=getIn(pin);});
        });
        S.fbdSignals=signals;
        rule._lastError=null;
    } catch(e) {
        rule._lastError = e.message || String(e);
    }
}

// ── Persistence ───────────────────────────────────────────────────────────────
function makeRule(name, mode) {
    var ts=Date.now(),rnd=Math.floor(Math.random()*1000);
    return{id:'r_'+ts+'_'+rnd,name:name||'New Rule',enabled:true,mode:mode||'simple',simple:{conditionMode:'and',functionType:'direct',timerSeconds:10,conditions:[],actions:[]},fbd:{nodes:[],edges:[]},code:{script:'// Available read-only: adapters, levers, gameState, population\n// setLever(name, \'on\'|\'off\')  \u2014  log(msg)\n\n'}};
}
function migrateV2Rule(old) {
    var r=makeRule(old.adapterName+' \u2192 '+old.leverName,'simple');r.enabled=!!old.enabled;r.simple.conditions=[{type:'adapter',adapterName:old.adapterName,adapterState:old.adapterState}];r.simple.actions=[{leverName:old.leverName,leverState:old.leverState}];return r;
}
function loadRules() {
    try{var v3=JSON.parse(localStorage.getItem('tac_rules_v3')||'null');if(Array.isArray(v3)&&v3.length)return v3;}catch(e){}
    try{var v2=JSON.parse(localStorage.getItem('tac_rules_v2')||'null');if(Array.isArray(v2)&&v2.length){var m=v2.map(migrateV2Rule);try{localStorage.setItem('tac_rules_v3',JSON.stringify(m));}catch(e){}return m;}}catch(e){}
    return[];
}
var _saveTimer = null;
function saveRules() {
    try { localStorage.setItem('tac_rules_v3', JSON.stringify(S.rules)); } catch(e) {}
    // Debounced server POST — only when a save is loaded
    if(S.currentSaveName) {
        clearTimeout(_saveTimer);
        _saveTimer = setTimeout(function() {
            if(!S.currentSaveName) return;
            var body = JSON.stringify(
                {rules: S.rules},
                function(k,v) { return (typeof k === 'string' && k.charAt(0) === '_') ? undefined : v; }
            );
            fetch('/api/automation?save=' + encodeURIComponent(S.currentSaveName), {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: body
            }).then(function(r) {
                if(r.ok) uiLog('sync', 'Rules synced to server for "' + S.currentSaveName + '" (' + S.rules.length + ' rules)');
                else     uiLog('warn', 'Server sync failed: HTTP ' + r.status + ' for "' + S.currentSaveName + '"');
            }).catch(function(e) { uiLog('warn', 'Server sync error: ' + (e.message||e)); });
        }, 500);
    }
}

// Called when poll detects a new/changed saveName from /api/gamestate.
// Fetches the rule set for that save from the backend.
// If the server has no rules yet (first time), migrates current in-memory rules to it.
function loadRulesFromServer(saveName) {
    S.currentSaveName = saveName;
    var snel = document.getElementById('tac-savename');
    if(snel) snel.textContent = '\uD83D\uDCBE ' + saveName;
    uiLog('sync', 'Save detected: "' + saveName + '" \u2014 fetching rules from server\u2026');
    get('/api/automation?save=' + encodeURIComponent(saveName)).then(function(data) {
        // Server returns {rules:[...]} — handle both wrapped and raw array just in case
        var loaded = Array.isArray(data) ? data
                   : (data && Array.isArray(data.rules)) ? data.rules
                   : null;
        if(loaded === null) { uiLog('warn', 'Server returned unexpected format for save "' + saveName + '"'); return; }
        if(loaded.length > 0) {
            // Fill in any missing sub-objects so old saves don't crash the engine
            S.rules = loaded.map(function(r) { return Object.assign({}, makeRule(r.name, r.mode), r); });
            try { localStorage.setItem('tac_rules_v3', JSON.stringify(S.rules)); } catch(e) {}
            uiLog('ok', 'Loaded ' + S.rules.length + ' rule' + (S.rules.length!==1?'s':'') + ' from server for "' + saveName + '"');
        } else if(S.rules.length > 0) {
            // No server rules yet for this save but we have rules in memory — migrate them up
            uiLog('sync', 'No server rules for "' + saveName + '" \u2014 uploading ' + S.rules.length + ' local rule' + (S.rules.length!==1?'s':''));
            saveRules();
        } else {
            uiLog('info', 'No rules for save "' + saveName + '" (clean start)');
        }
        // Re-render automation tab if it's open so the list reflects the loaded rules
        if(S.tab === 'automation') render();
    }).catch(function() { uiLog('warn', 'Could not reach server for save rules \u2014 using local rules'); });
}

