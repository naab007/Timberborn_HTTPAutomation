}
function fbdOnMouseUp(e) {
    if(FBD.panning){FBD.panning=false;FBD.panStart=null;return;}
    if(FBD.drag){var rule0=S.rules.find(function(r){return r.id===FBD.ruleId;});if(rule0)saveRules();FBD.drag=null;return;}
    if(FBD.wire&&e.button===0){
        var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});
        if(rule){
            // Prefer snap target over exact pin hit — snap wins within 300px
            var snapPin=FBD.snapTarget;
            var w=fbdScreenToWorld(e.clientX,e.clientY);
            var hitPin=snapPin||fbdPinAt(w.x,w.y,rule.fbd.nodes);
            if(hitPin&&hitPin.isInput&&hitPin.node.id!==FBD.wire.fromNodeId){
                fbdPushUndo(rule);
                // Remove any existing edge going into this input pin (one edge per input)
                rule.fbd.edges=rule.fbd.edges.filter(function(ed){return!(ed.toNodeId===hitPin.node.id&&ed.toPin===hitPin.pin);});
                rule.fbd.edges.push({id:fbdMakeEdgeId(),fromNodeId:FBD.wire.fromNodeId,fromPin:FBD.wire.fromPin,toNodeId:hitPin.node.id,toPin:hitPin.pin});
                saveRules();
