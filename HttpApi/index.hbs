    var node=fbdNodeAt(w.x,w.y,rule.fbd.nodes);
    if(node){if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}FBD.selected=node.id;FBD.drag={nodeId:node.id,offX:w.x-node.x,offY:w.y-node.y};fbdRefreshSidebar(rule);fbdDrawCanvas();return;}
    FBD.selected=null;if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}fbdRefreshSidebar(rule);fbdDrawCanvas();
}
function fbdOnMouseMove(e) {
    var w=fbdScreenToWorld(e.clientX,e.clientY);FBD.mouse=w;
    if(FBD.panning){FBD.pan.x=FBD.panStart.px+(e.clientX-FBD.panStart.mx);FBD.pan.y=FBD.panStart.py+(e.clientY-FBD.panStart.my);fbdDrawCanvas();return;}
    if(FBD.drag){var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});if(rule){var node=rule.fbd.nodes.find(function(n){return n.id===FBD.drag.nodeId;});if(node){node.x=Math.round(w.x-FBD.drag.offX);node.y=Math.round(w.y-FBD.drag.offY);}}fbdDrawCanvas();return;}
    if(FBD.wire){
        // Compute snap target — closest input pin within 300px
        var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});
        FBD.snapTarget=rule?fbdSnapTarget(w.x,w.y,rule.fbd.nodes,FBD.wire.fromNodeId):null;
    } else {
        FBD.snapTarget=null;
