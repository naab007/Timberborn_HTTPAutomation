        case'INPUT_LEVER':html+=pRow('Lever',mkSel('leverName',S.levers.length?S.levers.map(function(l){return[l.name,l.name];}):[['',' — ']],p.leverName));html+=pRow('Is',mkSel('leverState',[['on','ON'],['off','OFF']],p.leverState||'on'));break;
        case'INPUT_SENSOR':html+=pRow('Sensor',mkSel('sensorName',S.sensors.length?S.sensors.map(function(s){return[s.name,s.name];}):[['',' — no sensors — ']],p.sensorName));html+=pRow('Signal',mkSel('sensorState',[['on','ON (active)'],['off','OFF (inactive)']],p.sensorState||'on'));break;
        case'INPUT_GAMESTATE':html+=pRow('Field',mkSel('field',[['isDay','Daytime'],['isNight','Nighttime'],['isDrought','Drought'],['isBadtide','Badtide'],['isHazardous','Hazardous (legacy)'],['weatherIsHazardous','Any Hazardous Weather']],p.field||'isDay'));break;
        case'INPUT_TIME':html+=pRow('From (h)',mkNum('fromHour',p.fromHour,0,23,0.5));html+=pRow('To (h)',mkNum('toHour',p.toHour,0,23,0.5));break;
        case'INPUT_POPULATION':case'LOGIC_COMPARE':html+=pRow('Field',mkSel('field',popF,p.field||'homeless'));html+=pRow('Operator',mkSel('op',opO,p.op||'gt'));html+=pRow('Threshold',mkNum('threshold',p.threshold,0,9999,1));break;
        case'LOGIC_TIMER':html+=pRow('On Delay (s)',mkNum('preset',p.preset,1,3600,1));break;
