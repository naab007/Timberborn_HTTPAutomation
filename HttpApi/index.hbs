    if(e.button===1||(e.button===0&&FBD.spaceDown)){FBD.panning=true;FBD.panStart={mx:e.clientX,my:e.clientY,px:FBD.pan.x,py:FBD.pan.y};e.preventDefault();return;}
    if(e.button!==0)return;
    if(FBD.paramInputs.length&&FBD.selected){for(var _i=0;_i<FBD.paramInputs.length;_i++){var _pi=FBD.paramInputs[_i];if(w.x>=_pi.x&&w.x<=_pi.x+_pi.w&&w.y>=_pi.y&&w.y<=_pi.y+_pi.h){fbdShowInlineInput(_pi);e.preventDefault();return;}}}
    var pin=fbdPinAt(w.x,w.y,rule.fbd.nodes);
