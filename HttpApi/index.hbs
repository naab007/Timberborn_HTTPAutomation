        case'LOGIC_CTU':  html+=pRow('Preset count',mkNum('preset',p.preset,1,9999,1));break;
        case'LOGIC_RTC':  html+=pRow('From (h)',mkNum('fromHour',p.fromHour,0,23,0.5));html+=pRow('To (h)',mkNum('toHour',p.toHour,0,23,0.5));break;
        case'OUTPUT_LEVER':html+=pRow('Lever',mkSel('leverName',S.levers.length?S.levers.map(function(l){return[l.name,l.name];}):[['',' — ']],p.leverName));html+=pRow('Set to',mkSel('leverState',[['on','ON'],['off','OFF']],p.leverState||'on'));html+=pRow('Spring return','<label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.78rem"><input type="checkbox" '+(p.springReturn!==false?'checked':'')+' onchange="TAC._fbdUpdateParam(\''+rid+'\',\''+nid+'\',\'springReturn\',this.checked)"> Auto-off when IN goes LOW</label>');break;
