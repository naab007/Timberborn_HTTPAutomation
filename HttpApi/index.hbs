    var nodes=rule.fbd.nodes,minX=Infinity,minY=Infinity,maxX=-Infinity,maxY=-Infinity;
    nodes.forEach(function(n){minX=Math.min(minX,n.x);minY=Math.min(minY,n.y);maxX=Math.max(maxX,n.x+FBD_W);maxY=Math.max(maxY,n.y+fbdNodeH(n.type));});
