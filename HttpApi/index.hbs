    card.innerHTML='<h4 style="color:#e6edf3;margin:0 0 1rem">'+esc(title)+'</h4>'
        +'<p style="color:#8b949e;white-space:pre-wrap;margin:0 0 1.5rem;font-size:.9rem">'+esc(text)+'</p>'
