// Pin snap: finds the closest input pin within FBD_SNAP_RADIUS world-units.
// Only snaps to input pins on nodes other than the wire's source node.
var FBD_SNAP_RADIUS = 300;
function fbdSnapTarget(wx, wy, nodes, fromNodeId) {
    var best=null, bestDist=FBD_SNAP_RADIUS;
    for(var i=0;i<nodes.length;i++){
        var n=nodes[i];if(n.id===fromNodeId)continue;
        var d=FBD_DEFS[n.type];if(!d||!d.inputs.length)continue;
        for(var j=0;j<d.inputs.length;j++){
            var p=fbdPinPos(n,true,j);
            var dist=Math.hypot(wx-p.x,wy-p.y);
            if(dist<bestDist){bestDist=dist;best={node:n,pin:d.inputs[j],pos:p,dist:bestDist,isInput:true};}
        }
    }
    return best;
}

// ── FBD canvas events ──────────────────────────────────────────────────────────
function fbdOnMouseDown(e) {
