<script>
// ── Global error handler — surfaces JS errors that would otherwise fail silently ──
window.onerror = function(msg, src, line, col, err) {
    var text = 'JS ERROR: ' + msg + ' (line ' + line + ')';
    var el = document.getElementById('tac-err');
    if (el) {
        el.textContent = text;
        el.className = 'alert alert-danger position-fixed bottom-0 start-50 translate-middle-x mb-3 shadow';
        el.style.cssText = 'z-index:9999;text-align:center;min-width:260px;display:block';
    } else {
        alert(text);
    }
    return false; // let the browser also log it
};
(function () {
'use strict';

// ── Fallback detection ────────────────────────────────────────────────────────
var DLL_AVAILABLE = null;

// ── State ─────────────────────────────────────────────────────────────────────
var S = {
    levers:         (window.TB && window.TB.levers)   || [],
    adapters:       (window.TB && window.TB.adapters) || [],
    sensors:        [],
    gameState:      null,
    population:     null,
    beavers:        [],
    beaversLoaded:  false,
    rules:          loadRules(),
    tab:            'dashboard',
    polling:        false,
    automationView: 'list',
    editingRuleId:  null,
    codeLogs:       {},   // { [ruleId]: [{time, msg, isErr}] }
    fbdSignals:     {},   // { 'nodeId_pinName': boolean }
    showImport:      false,  // whether import JSON panel is open
    currentSaveName: '',     // save name last loaded from server; '' = no save loaded yet
    uiLog:           [],     // [{time, level, msg}]  frontend activity log
    logFilter:       'all'   // 'all' | 'ok' | 'warn' | 'err' | 'rule'
};

// ── Frontend activity log ─────────────────────────────────────────────────────
var UI_LOG_MAX = 300;
var UI_LOG_LEVELS = { ok:'ok', info:'info', warn:'warn', err:'err', rule:'rule', sync:'sync' };

function uiLog(level, msg) {
    var now = new Date();
    var ts  = now.getHours().toString().padStart(2,'0') + ':'
            + now.getMinutes().toString().padStart(2,'0') + ':'
            + now.getSeconds().toString().padStart(2,'0');
    S.uiLog.unshift({ time: ts, level: level, msg: msg });
    if (S.uiLog.length > UI_LOG_MAX) S.uiLog.length = UI_LOG_MAX;
    // Patch log panel if it's visible without a full render
    if (S.tab === 'logs') {
        var panel = document.getElementById('tac-log-panel');
        if (panel) panel.innerHTML = renderLogLines();
    }
}

// ── FBD canvas runtime state (not persisted) ──────────────────────────────────
var FBD = {
    canvas: null, ctx: null, ruleId: null,
    pan: { x: 20, y: 20 },
    zoom: 1.0,
    drag: null, wire: null, selected: null,
    mouse: { x: 0, y: 0 },
    spaceDown: false, panning: false, panStart: null,
    paramInputs: [],   // [{nodeId,key,type,opts,min,max,step,val,x,y,w,h}] world-space hit rects
    inlineInput: null  // currently active overlay <input>/<select> element
};

// ── FBD node type definitions ─────────────────────────────────────────────────
// needsDll flag: node evaluates to false when DLL unavailable (graceful degradation)
var FBD_DEFS = {
    INPUT_ADAPTER:    { label:'Adapter',     cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:false },
    INPUT_LEVER:      { label:'Lever State', cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:false },
    INPUT_SENSOR:     { label:'Sensor',      cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:true  },
    INPUT_GAMESTATE:  { label:'Game State', cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:true  },
    INPUT_TIME:       { label:'Time Range', cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:true  },
    INPUT_POPULATION: { label:'Population', cat:'Input',  color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:true  },
    LOGIC_AND:        { label:'AND',        cat:'Logic',  color:'#1a3d1a', inputs:['A','B'], outputs:['Q'], needsDll:false },
    LOGIC_OR:         { label:'OR',         cat:'Logic',  color:'#1a3d1a', inputs:['A','B'], outputs:['Q'], needsDll:false },
    LOGIC_NAND:       { label:'NAND',       cat:'Logic',  color:'#1a3d1a', inputs:['A','B'], outputs:['Q'], needsDll:false },
    LOGIC_NOR:        { label:'NOR',        cat:'Logic',  color:'#1a3d1a', inputs:['A','B'], outputs:['Q'], needsDll:false },
    LOGIC_NOT:        { label:'NOT',        cat:'Logic',  color:'#1a3d1a', inputs:['IN'],    outputs:['Q'], needsDll:false },
    LOGIC_TIMER:      { label:'TON (On Delay)',  cat:'Logic',  color:'#3d2a00', inputs:['IN'],    outputs:['Q'], needsDll:false },
    LOGIC_TOF:        { label:'TOF (Off Delay)', cat:'Logic',  color:'#3d2a00', inputs:['IN'],    outputs:['Q'], needsDll:false },
    LOGIC_TP:         { label:'TP (Pulse)',      cat:'Logic',  color:'#3d2a00', inputs:['IN'],    outputs:['Q'], needsDll:false },
    LOGIC_GEN:        { label:'Generator',       cat:'Logic',  color:'#3d2a00', inputs:['IN'],    outputs:['Q'], needsDll:false },
    LOGIC_CTU:        { label:'Counter (CTU)',   cat:'Logic',  color:'#3d2a00', inputs:['CU','R'],outputs:['Q'], needsDll:false },
    LOGIC_RTC:        { label:'Real-Time Clock', cat:'Logic',  color:'#3d2a00', inputs:[],        outputs:['Q'], needsDll:false },
    LOGIC_SRLATCH:    { label:'SR-Latch',   cat:'Logic',  color:'#3d2a00', inputs:['S','R'], outputs:['Q'], needsDll:false },
    LOGIC_COMPARE:    { label:'Compare',    cat:'Logic',  color:'#1a3d1a', inputs:[],        outputs:['Q'], needsDll:true  },
    ALWAYS_HIGH:      { label:'Always HIGH', cat:'Input', color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:false },
    ALWAYS_LOW:       { label:'Always LOW',  cat:'Input', color:'#0d3a5c', inputs:[],        outputs:['Q'], needsDll:false },
    OUTPUT_LEVER:     { label:'Set Lever',  cat:'Output', color:'#4a1010', inputs:['IN'],    outputs:[],    needsDll:false }
};
var FBD_W = 150, FBD_ROW = 22, FBD_HEAD = 26, FBD_PAD = 8;
var FBD_PR = 6;        // visual pin radius (drawn circle)
var FBD_PR_HIT = 12;   // invisible hit radius (easier to connect)
var FBD_UNDO = [];     // [{nodes:[], edges:[]}] undo stack for current rule
var FBD_UNDO_MAX = 20;
function fbdPushUndo(rule){if(!rule||!rule.fbd)return;FBD_UNDO.push(JSON.stringify({nodes:rule.fbd.nodes,edges:rule.fbd.edges}));if(FBD_UNDO.length>FBD_UNDO_MAX)FBD_UNDO.shift();}
function fbdUndo(rule){if(!rule||!rule.fbd||!FBD_UNDO.length)return;var snap=JSON.parse(FBD_UNDO.pop());rule.fbd.nodes=snap.nodes;rule.fbd.edges=snap.edges;FBD.selected=null;if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}saveRules();fbdDrawCanvas();}

function fbdNodeH(type) { var d=FBD_DEFS[type]; if(!d)return 60; return FBD_HEAD+Math.max(d.inputs.length,d.outputs.length,1)*FBD_ROW+FBD_PAD; }
function fbdPinPos(node, isInput, idx) { return { x: isInput ? node.x : node.x+FBD_W, y: node.y+FBD_HEAD+idx*FBD_ROW+FBD_ROW/2 }; }
function fbdMakeNodeId() { return 'n_'+Date.now()+'_'+Math.floor(Math.random()*1000); }
function fbdMakeEdgeId() { return 'e_'+Date.now()+'_'+Math.floor(Math.random()*1000); }
function fbdScreenToWorld(sx, sy) { if(!FBD.canvas)return{x:0,y:0}; var r=FBD.canvas.getBoundingClientRect(); return{x:(sx-r.left-FBD.pan.x)/FBD.zoom, y:(sy-r.top-FBD.pan.y)/FBD.zoom}; }
function fbdNodeAt(wx, wy, nodes) { for(var i=nodes.length-1;i>=0;i--){var n=nodes[i];if(wx>=n.x&&wx<=n.x+FBD_W&&wy>=n.y&&wy<=n.y+fbdNodeH(n.type))return n;} return null; }
function fbdPinAt(wx, wy, nodes) {
    for(var i=0;i<nodes.length;i++){var n=nodes[i],d=FBD_DEFS[n.type];if(!d)continue;
        for(var j=0;j<d.inputs.length;j++){var p=fbdPinPos(n,true,j);if(Math.hypot(wx-p.x,wy-p.y)<FBD_PR_HIT)return{node:n,isInput:true,pin:d.inputs[j]};}
        for(var k=0;k<d.outputs.length;k++){var q=fbdPinPos(n,false,k);if(Math.hypot(wx-q.x,wy-q.y)<FBD_PR_HIT)return{node:n,isInput:false,pin:d.outputs[k]};}}
    return null;
}
function fbdBezierDist(px, py, x0, y0, x1, y1) {
    var cx=Math.abs(x1-x0)*0.5+40, minD=Infinity;
    for(var t=0;t<=1;t+=0.05){var u=1-t;var bx=u*u*u*x0+3*u*u*t*(x0+cx)+3*u*t*t*(x1-cx)+t*t*t*x1;var by=u*u*u*y0+3*u*u*t*y0+3*u*t*t*y1+t*t*t*y1;minD=Math.min(minD,Math.hypot(px-bx,py-by));}
    return minD;
}
function fbdHitEdge(wx, wy, nodes, edges) {
    for(var i=0;i<edges.length;i++){var e=edges[i];var fn=nodes.find(function(n){return n.id===e.fromNodeId;});var tn=nodes.find(function(n){return n.id===e.toNodeId;});if(!fn||!tn)continue;var fd=FBD_DEFS[fn.type],td=FBD_DEFS[tn.type];if(!fd||!td)continue;var fi=fd.outputs.indexOf(e.fromPin),ti=td.inputs.indexOf(e.toPin);if(fi<0||ti<0)continue;var p0=fbdPinPos(fn,false,fi),p1=fbdPinPos(tn,true,ti);if(fbdBezierDist(wx,wy,p0.x,p0.y,p1.x,p1.y)<8)return e;}
    return null;
}
function fbdDefaultParams(type) {
    switch(type){
        case'INPUT_ADAPTER':  return{adapterName:(S.adapters[0]&&S.adapters[0].name)||'',adapterState:'on'};
        case'INPUT_SENSOR':   return{sensorName:(S.sensors[0]&&S.sensors[0].name)||'',sensorState:'on'};
        case'INPUT_GAMESTATE':return{field:'isDay'};
        case'INPUT_TIME':     return{fromHour:6,toHour:20};
        case'INPUT_POPULATION':return{field:'homeless',op:'gt',threshold:0};
        case'ALWAYS_HIGH':    return{};
        case'ALWAYS_LOW':     return{};
        case'LOGIC_TIMER':    return{preset:10};
        case'LOGIC_TOF':      return{preset:10};
        case'LOGIC_TP':       return{preset:5};
        case'LOGIC_GEN':      return{onTime:5,offTime:5};
        case'LOGIC_CTU':      return{preset:5};
        case'LOGIC_RTC':      return{fromHour:8,toHour:18};
        case'LOGIC_COMPARE':  return{field:'homeless',op:'gt',threshold:0};
        case'OUTPUT_LEVER':   return{leverName:(S.levers[0]&&S.levers[0].name)||'',leverState:'on',springReturn:true};
        default:return{};
    }
}
function fbdNodeParamSummary(node) {
    var p=node.params||{};
    switch(node.type){
        case'INPUT_ADAPTER':  return(p.adapterName||'?')+' '+(p.adapterState||'on').toUpperCase();
        case'INPUT_SENSOR':   return(p.sensorName||'?')+' is '+(p.sensorState||'on').toUpperCase();
        case'INPUT_GAMESTATE':return p.field||'?';
        case'INPUT_TIME':     return(p.fromHour||0)+'\u2013'+(p.toHour||12)+'h';
        case'INPUT_POPULATION':return(p.field||'?')+' '+(p.op||'>')+' '+(p.threshold||0);
        case'ALWAYS_HIGH':    return 'TRUE';
        case'ALWAYS_LOW':     return 'FALSE';
        case'LOGIC_TIMER':    return'TON PT='+(p.preset||10)+'s';
        case'LOGIC_TOF':      return'TOF PT='+(p.preset||10)+'s';
        case'LOGIC_TP':       return'TP PT='+(p.preset||5)+'s';
        case'LOGIC_GEN':      return'ON='+(p.onTime||5)+'s OFF='+(p.offTime||5)+'s';
        case'LOGIC_CTU':      return'PV='+(p.preset||5);
        case'LOGIC_RTC':      return(p.fromHour||8)+'\u2013'+(p.toHour||18)+'h';
        case'LOGIC_COMPARE':  return(p.field||'?')+' '+(p.op||'>')+' '+(p.threshold||0);
        case'OUTPUT_LEVER':   return(p.leverName||'?')+' \u2192 '+(p.leverState||'on').toUpperCase()+(p.springReturn?' \u21ba':'');
        default:return'';
    }
}
function fbdParamDefs(node){
    var p=node.params||{};
    var adapOpts=S.adapters.length?S.adapters.map(function(a){return[a.name,a.name];}):[['',' — ']];
    var leverOpts=S.levers.length?S.levers.map(function(l){return[l.name,l.name];}):[['',' — ']];
    var sensorOpts=S.sensors.length?S.sensors.map(function(s){return[s.name,s.name];}):[['',' — ']];
    var onOff=[['on','ON'],['off','OFF']];
    var popF=[['totalBeavers','Total'],['adults','Adults'],['children','Children'],['unemployed','Idle'],['homeless','Homeless'],['injured','Injured'],['contaminated','Contam.']];
    var opO=[['gt','>'],['gte','\u2265'],['lt','<'],['lte','\u2264'],['eq','=']];
    var gsF=[['isDay','Daytime'],['isNight','Nighttime'],['isDrought','Drought'],['isBadtide','Badtide'],['isHazardous','Hazardous'],['weatherIsHazardous','Any Hazardous']];
    switch(node.type){
        case'INPUT_ADAPTER':return[{key:'adapterName',label:'Adapter',type:'select',opts:adapOpts,val:p.adapterName},{key:'adapterState',label:'State',type:'select',opts:onOff,val:p.adapterState||'on'}];
        case'INPUT_LEVER':return[{key:'leverName',label:'Lever',type:'select',opts:leverOpts,val:p.leverName},{key:'leverState',label:'Is',type:'select',opts:onOff,val:p.leverState||'on'}];
        case'INPUT_SENSOR':return[{key:'sensorName',label:'Sensor',type:'select',opts:sensorOpts,val:p.sensorName},{key:'sensorState',label:'Signal',type:'select',opts:onOff,val:p.sensorState||'on'}];
        case'INPUT_GAMESTATE':return[{key:'field',label:'Field',type:'select',opts:gsF,val:p.field||'isDay'}];
        case'INPUT_TIME':return[{key:'fromHour',label:'From (h)',type:'number',min:0,max:23,step:0.5,val:p.fromHour!==undefined?p.fromHour:6},{key:'toHour',label:'To (h)',type:'number',min:0,max:23,step:0.5,val:p.toHour!==undefined?p.toHour:20}];
        case'INPUT_POPULATION':case'LOGIC_COMPARE':return[{key:'field',label:'Field',type:'select',opts:popF,val:p.field||'homeless'},{key:'op',label:'Op',type:'select',opts:opO,val:p.op||'gt'},{key:'threshold',label:'Value',type:'number',min:0,max:9999,step:1,val:p.threshold!==undefined?p.threshold:0}];
        case'LOGIC_TIMER':return[{key:'preset',label:'On Delay (s)',type:'number',min:1,max:3600,step:1,val:p.preset!==undefined?p.preset:10}];
        case'LOGIC_TOF':return[{key:'preset',label:'Off Delay (s)',type:'number',min:1,max:3600,step:1,val:p.preset!==undefined?p.preset:10}];
        case'LOGIC_TP':return[{key:'preset',label:'Pulse (s)',type:'number',min:1,max:3600,step:1,val:p.preset!==undefined?p.preset:5}];
        case'LOGIC_GEN':return[{key:'onTime',label:'ON time (s)',type:'number',min:0.5,max:3600,step:0.5,val:p.onTime!==undefined?p.onTime:5},{key:'offTime',label:'OFF time (s)',type:'number',min:0.5,max:3600,step:0.5,val:p.offTime!==undefined?p.offTime:5}];
        case'LOGIC_CTU':return[{key:'preset',label:'Preset count',type:'number',min:1,max:9999,step:1,val:p.preset!==undefined?p.preset:5}];
        case'LOGIC_RTC':return[{key:'fromHour',label:'From (h)',type:'number',min:0,max:23,step:0.5,val:p.fromHour!==undefined?p.fromHour:8},{key:'toHour',label:'To (h)',type:'number',min:0,max:23,step:0.5,val:p.toHour!==undefined?p.toHour:18}];
        case'OUTPUT_LEVER':return[{key:'leverName',label:'Lever',type:'select',opts:leverOpts,val:p.leverName},{key:'leverState',label:'Set to',type:'select',opts:onOff,val:p.leverState||'on'},{key:'springReturn',label:'Spring return',type:'boolean',val:p.springReturn!==false}];
        default:return[];
    }
}
function fbdDrawParamPanel(ctx,node){
    var defs=fbdParamDefs(node);if(!defs.length)return;
    var PAD=8,ROW_H=24,LABEL_W=78,PW=FBD_W+20,PH=PAD+defs.length*ROW_H+PAD;
    var px=node.x-10,py=node.y+fbdNodeH(node.type)+6;
    fbdRoundRect(ctx,px,py,PW,PH,5);ctx.fillStyle='rgba(13,17,23,0.93)';ctx.fill();
    ctx.strokeStyle='#4d9fff';ctx.lineWidth=1.5;ctx.stroke();
    ctx.fillStyle='#4d9fff';ctx.font='bold 8px Consolas,monospace';ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText('PARAMS',px+PAD,py+3);
    defs.forEach(function(def,i){
        var ry=py+PAD+i*ROW_H,valX=px+PAD+LABEL_W,valW=PW-PAD-LABEL_W-PAD,valH=ROW_H-6;
        ctx.fillStyle='#8b949e';ctx.font='9px Consolas,monospace';ctx.textAlign='left';ctx.textBaseline='middle';
        ctx.fillText(def.label,px+PAD,ry+ROW_H/2);
        ctx.fillStyle='rgba(255,255,255,0.07)';ctx.strokeStyle='rgba(255,255,255,0.22)';ctx.lineWidth=1;
        ctx.fillRect(valX,ry+3,valW,valH);ctx.strokeRect(valX,ry+3,valW,valH);
        if(def.type==='boolean'){
            ctx.fillStyle=def.val?'#007a30':'#3a3a3a';ctx.fillRect(valX+2,ry+5,valW-4,valH-4);
            ctx.fillStyle='#e6edf3';ctx.font='9px Consolas,monospace';ctx.textAlign='center';ctx.textBaseline='middle';
            ctx.fillText(def.val?'ON':'OFF',valX+valW/2,ry+ROW_H/2);
        } else {
            var dv=def.type==='select'?(def.opts&&def.opts.find(function(o){return o[0]===def.val;}))||(def.val!==undefined?[def.val,String(def.val)]:[['','']]):null;
            var dispStr=def.type==='select'?(dv?dv[1]:String(def.val)):String(def.val!==undefined?def.val:'');
            ctx.fillStyle='#e6edf3';ctx.font='9px Consolas,monospace';ctx.textAlign='left';ctx.textBaseline='middle';
            ctx.fillText(String(dispStr).substring(0,16),valX+3,ry+ROW_H/2);
        }
        FBD.paramInputs.push({nodeId:node.id,key:def.key,type:def.type,opts:def.opts,min:def.min,max:def.max,step:def.step,val:def.val,x:valX,y:ry+3,w:valW,h:valH});
    });
}
function fbdRemoveInlineInput(el){if(!el)return;try{if(el.parentNode)el.parentNode.removeChild(el);}catch(ex){}}
function fbdShowInlineInput(pi){
    if(FBD.inlineInput){fbdRemoveInlineInput(FBD.inlineInput);FBD.inlineInput=null;}
    if(!FBD.canvas)return;
    var rect=FBD.canvas.getBoundingClientRect();
    var sx=Math.round(pi.x*FBD.zoom+FBD.pan.x+rect.left),sy=Math.round(pi.y*FBD.zoom+FBD.pan.y+rect.top);
    var sw=Math.max(40,Math.round(pi.w*FBD.zoom))+4,sh=Math.max(16,Math.round(pi.h*FBD.zoom))+2;
    var baseStyle='position:fixed;z-index:9999;font-size:'+Math.max(9,Math.round(11*FBD.zoom))+'px;font-family:Consolas,monospace;background:#1a1f2e;color:#e6edf3;border:1px solid #4d9fff;border-radius:2px;padding:1px 3px;left:'+sx+'px;top:'+sy+'px;width:'+sw+'px;height:'+sh+'px;outline:none';
    if(pi.type==='boolean'){
        var rule=S.rules.find(function(r){return r.id===FBD.ruleId;});
        if(rule){var node=rule.fbd.nodes.find(function(n){return n.id===pi.nodeId;});if(node){if(!node.params)node.params={};node.params[pi.key]=!pi.val;saveRules();fbdRefreshSidebar(rule);fbdDrawCanvas();}}
        return;
    }
    var el;
    if(pi.type==='select'){
        el=document.createElement('select');el.style.cssText=baseStyle;
        (pi.opts||[]).forEach(function(o){var opt=document.createElement('option');opt.value=o[0];opt.textContent=o[1];if(o[0]===pi.val)opt.selected=true;el.appendChild(opt);});
        el.addEventListener('change',function(){TAC._fbdUpdateParam(FBD.ruleId,pi.nodeId,pi.key,el.value);fbdRemoveInlineInput(el);FBD.inlineInput=null;});
        el.addEventListener('blur',function(){if(el.parentNode){fbdRemoveInlineInput(el);FBD.inlineInput=null;fbdDrawCanvas();}});
    } else {
        el=document.createElement('input');el.type='number';el.value=pi.val;
        if(pi.min!==undefined)el.min=pi.min;if(pi.max!==undefined)el.max=pi.max;if(pi.step!==undefined)el.step=pi.step;
        el.style.cssText=baseStyle;
        el.addEventListener('keydown',function(ev){if(ev.key==='Enter'||ev.key==='Tab'){ev.preventDefault();TAC._fbdUpdateParam(FBD.ruleId,pi.nodeId,pi.key,+el.value);fbdRemoveInlineInput(el);FBD.inlineInput=null;}if(ev.key==='Escape'){fbdRemoveInlineInput(el);FBD.inlineInput=null;fbdDrawCanvas();}});
        el.addEventListener('blur',function(){if(el.parentNode){TAC._fbdUpdateParam(FBD.ruleId,pi.nodeId,pi.key,+el.value);fbdRemoveInlineInput(el);FBD.inlineInput=null;}});
    }
    document.body.appendChild(el);FBD.inlineInput=el;el.focus();if(el.select)el.select();
}

// ── FBD canvas draw ───────────────────────────────────────────────────────────
function fbdRoundRect(ctx, x, y, w, h, r) {
    ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();
}
function fbdDrawWire(ctx, x0, y0, x1, y1, signal, dashed) {
    var cx=Math.max(40,Math.abs(x1-x0)*0.45);
    ctx.beginPath();ctx.moveTo(x0,y0);ctx.bezierCurveTo(x0+cx,y0,x1-cx,y1,x1,y1);
    ctx.strokeStyle=dashed?'rgba(255,255,255,.45)':signal===true?'#00cc00':signal===false?'#3a6080':'#557';
    ctx.lineWidth=dashed?1.5:2;ctx.setLineDash(dashed?[5,4]:[]);ctx.stroke();ctx.setLineDash([]);
}
function fbdDrawPin(ctx, x, y, isInput, label, signal) {
    // Hover highlight — cyan glow ring when mouse is within hit radius
    var mx=FBD.mouse?FBD.mouse.x:null, my=FBD.mouse?FBD.mouse.y:null;
